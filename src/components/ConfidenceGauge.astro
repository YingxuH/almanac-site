---
// Animated radial gauge — shows overall system confidence
interface Props {
  value: number;
  label?: string;
  size?: number;
}
const { value, label = "Avg Confidence", size = 200 } = Astro.props;
const circumference = 2 * Math.PI * 70;
const offset = circumference - (value / 100) * circumference * 0.75; // 270 degree arc
const color = value >= 75 ? 'var(--color-almanac-green)' : value >= 60 ? 'var(--color-almanac-amber)' : 'var(--color-almanac-red)';
---
<div class="gauge-container relative" style={`width: ${size}px; height: ${size}px`}>
  <svg viewBox="0 0 200 200" class="w-full h-full -rotate-[135deg]">
    {/* Background arc */}
    <circle cx="100" cy="100" r="70" fill="none" stroke="var(--color-almanac-border)" stroke-width="12" stroke-linecap="round"
      stroke-dasharray={`${circumference * 0.75} ${circumference * 0.25}`} />
    {/* Value arc */}
    <circle cx="100" cy="100" r="70" fill="none" stroke={color} stroke-width="12" stroke-linecap="round"
      stroke-dasharray={`${circumference * 0.75} ${circumference * 0.25}`}
      stroke-dashoffset={offset}
      class="gauge-fill" />
    {/* Glow */}
    <circle cx="100" cy="100" r="70" fill="none" stroke={color} stroke-width="12" stroke-linecap="round"
      stroke-dasharray={`${circumference * 0.75} ${circumference * 0.25}`}
      stroke-dashoffset={offset}
      filter="blur(8px)" opacity="0.4"
      class="gauge-fill" />
  </svg>
  <div class="absolute inset-0 flex flex-col items-center justify-center">
    <span class="text-4xl font-bold font-mono gauge-number" data-value={value}>{value}%</span>
    <span class="text-[10px] text-almanac-muted uppercase tracking-widest mt-1">{label}</span>
  </div>
</div>

<style>
  .gauge-fill {
    animation: gauge-draw 1.5s ease-out forwards;
    transition: stroke-dashoffset 1s ease-out;
  }
  @keyframes gauge-draw {
    from { stroke-dashoffset: 329.87; } /* full circumference * 0.75 */
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target.querySelector('.gauge-number');
      if (!el || el.getAttribute('data-done')) return;
      el.setAttribute('data-done', '1');
      const target = parseInt(el.getAttribute('data-value') || '0');
      const start = performance.now();
      function update(now: number) {
        const progress = Math.min((now - start) / 1500, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el!.textContent = Math.round(eased * target).toString() + '%';
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.gauge-container').forEach(el => observer.observe(el));
</script>
