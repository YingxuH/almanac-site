---
// Floating gradient orbs that drift behind content
---
<div class="glow-container absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>

<style>
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.12;
  }
  .orb-1 {
    width: 500px;
    height: 500px;
    background: var(--color-almanac-accent);
    top: -10%;
    left: 20%;
    animation: float-1 15s ease-in-out infinite;
  }
  .orb-2 {
    width: 400px;
    height: 400px;
    background: var(--color-almanac-green);
    bottom: -5%;
    right: 15%;
    animation: float-2 18s ease-in-out infinite;
  }
  .orb-3 {
    width: 300px;
    height: 300px;
    background: var(--color-almanac-amber);
    top: 40%;
    left: -5%;
    animation: float-3 22s ease-in-out infinite;
    opacity: 0.06;
  }
  @keyframes float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }
  @keyframes float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-30px, 20px) scale(0.95); }
    66% { transform: translate(25px, -35px) scale(1.08); }
  }
  @keyframes float-3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(50px, -20px); }
  }
</style>
