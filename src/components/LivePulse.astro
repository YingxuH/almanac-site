---
// Animated connection lines showing data flowing from sources to the system
---
<div class="live-pulse-container relative w-full h-16 sm:h-24 overflow-hidden" aria-hidden="true">
  <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 1200 120">
    {/* Horizontal flowing lines */}
    {[20, 40, 60, 80, 100].map((y, i) => (
      <>
        <line x1="0" y1={y} x2="1200" y2={y} stroke="var(--color-almanac-border)" stroke-width="0.5" opacity="0.3"/>
        <circle r="3" fill="var(--color-almanac-accent)" opacity="0.8">
          <animateMotion dur={`${3 + i * 0.7}s`} repeatCount="indefinite" path={`M-10,${y} L1210,${y}`} />
        </circle>
        <circle r="3" fill="var(--color-almanac-green)" opacity="0.6">
          <animateMotion dur={`${4 + i * 0.5}s`} repeatCount="indefinite" begin={`${i * 0.3}s`} path={`M-10,${y} L1210,${y}`} />
        </circle>
      </>
    ))}
  </svg>
  <div class="absolute inset-0 bg-gradient-to-r from-almanac-bg via-transparent to-almanac-bg pointer-events-none"></div>
</div>
