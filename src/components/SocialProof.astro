---
interface Props {
  pipelineRuns: number;
  signalsProcessed: number;
}
const { pipelineRuns, signalsProcessed } = Astro.props;
const signalsDisplay = signalsProcessed >= 1000
  ? `${(signalsProcessed / 1000).toFixed(1)}k+`
  : `${signalsProcessed}+`;
const signalsDisplayZh = signalsDisplay;
---

<div class="max-w-5xl mx-auto px-4 sm:px-6 py-3">
  <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-almanac-muted">

    <!-- Consecutive pipeline runs -->
    <span class="flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-almanac-green flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
      <span
        data-en={`${pipelineRuns} consecutive pipeline runs`}
        data-zh={`已连续运行 ${pipelineRuns} 次`}
      >{pipelineRuns} consecutive pipeline runs</span>
    </span>

    <span class="text-almanac-border hidden sm:inline" aria-hidden="true">·</span>

    <!-- Signals processed -->
    <span class="flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-almanac-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
      <span
        data-en={`${signalsDisplay} signals processed`}
        data-zh={`已处理 ${signalsDisplayZh} 条信号`}
      >{signalsDisplay} signals processed</span>
    </span>

    <span class="text-almanac-border hidden sm:inline" aria-hidden="true">·</span>

    <!-- Open source -->
    <a
      href="https://github.com/YingxuH/almanac"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1.5 hover:text-almanac-accent transition-colors"
    >
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
      </svg>
      <span
        data-en="Open source on GitHub"
        data-zh="代码完全开源"
      >Open source on GitHub</span>
    </a>

    <span class="text-almanac-border hidden sm:inline" aria-hidden="true">·</span>

    <!-- Pipeline cost -->
    <span class="flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-almanac-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span
        data-en="Pipeline cost: $2.45/day"
        data-zh="Pipeline 运行成本：$2.45/天"
      >Pipeline cost: $2.45/day</span>
    </span>

  </div>
</div>
