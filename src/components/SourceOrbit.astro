---
// Data source visualization — orbit on desktop, grid on mobile
const sources = [
  "arXiv", "HN", "TechCrunch", "Ars Technica", "MIT Tech Review",
  "The Verge", "Wired", "GitHub", "S.Scholar", "Stack Overflow",
  "FRED", "SEC EDGAR", "Reddit", "Lobsters", "X/Twitter",
  "NVIDIA IR", "MSFT IR",
];
---

<!-- Mobile: clean grid of source badges -->
<div class="sm:hidden flex flex-wrap justify-center gap-2 max-w-sm mx-auto">
  {sources.map((src) => (
    <span class="inline-block px-2.5 py-1.5 text-xs font-mono rounded-md bg-almanac-surface border border-almanac-border text-almanac-muted">
      {src}
    </span>
  ))}
</div>

<!-- Desktop: animated orbit -->
<div class="orbit-container relative w-96 h-96 mx-auto hidden sm:block">
  <!-- Center pulse -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-20 h-20 rounded-full bg-almanac-accent/10 flex items-center justify-center">
    <div class="w-12 h-12 rounded-full bg-almanac-accent/20 flex items-center justify-center animate-pulse">
      <div class="w-6 h-6 rounded-full bg-almanac-accent/60"></div>
    </div>
  </div>

  <!-- Orbit ring -->
  <div class="absolute inset-4 rounded-full border border-almanac-border/40 orbit-ring"></div>

  <!-- Orbiting items -->
  {sources.map((src, i) => {
    const angle = (360 / sources.length) * i;
    return (
      <div
        class="orbit-item absolute"
        style={`--angle: ${angle}deg; --delay: ${i * -0.5}s;`}
      >
        <span class="inline-block px-2 py-1 text-xs font-mono rounded-md bg-almanac-surface border border-almanac-border text-almanac-muted whitespace-nowrap hover:text-almanac-accent hover:border-almanac-accent/50 transition-colors">
          {src}
        </span>
      </div>
    );
  })}
</div>

<style>
  .orbit-ring {
    animation: spin-slow 60s linear infinite;
  }
  .orbit-item {
    top: 50%;
    left: 50%;
    animation: orbit 25s linear infinite;
    animation-delay: var(--delay);
  }
  @keyframes orbit {
    from {
      transform: rotate(var(--angle)) translateX(165px) rotate(calc(-1 * var(--angle)));
    }
    to {
      transform: rotate(calc(var(--angle) + 360deg)) translateX(165px) rotate(calc(-1 * (var(--angle) + 360deg)));
    }
  }
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
