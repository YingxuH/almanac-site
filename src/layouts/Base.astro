---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "The modern almanac for an uncertain future. AI-powered daily forecasts about humanity's trajectory." } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('almanac-theme');
      if (t === 'light') {
        document.documentElement.classList.replace('dark', 'light');
      } else if (!t) {
        // Default to dark
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="bg-almanac-bg text-almanac-text font-sans antialiased min-h-screen transition-colors duration-300">
  <nav class="fixed top-0 w-full z-50 border-b border-almanac-border bg-almanac-bg/80 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight">
        <span class="text-almanac-accent">A</span>lmanac
      </a>
      <div class="flex items-center gap-6 text-sm text-almanac-muted">
        <a href="/forecast" class="hover:text-almanac-text transition">Today's Forecast</a>
        <a href="/predictions" class="hover:text-almanac-text transition">Predictions</a>
        <a href="https://github.com/YingxuH/almanac" class="hover:text-almanac-text transition">GitHub</a>
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="relative w-9 h-9 flex items-center justify-center rounded-lg border border-almanac-border hover:border-almanac-muted bg-almanac-surface transition-all duration-300 cursor-pointer"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg id="icon-sun" class="w-4 h-4 text-almanac-amber transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg id="icon-moon" class="w-4 h-4 text-almanac-accent transition-transform duration-300 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </div>
    </div>
  </nav>
  <main class="pt-14">
    <slot />
  </main>
  <footer class="border-t border-almanac-border mt-20 py-12">
    <div class="max-w-6xl mx-auto px-6 text-center text-sm text-almanac-muted">
      <p>Almanac — The modern almanac for an uncertain future.</p>
      <p class="mt-1">"We're cartographers, not prophets."</p>
    </div>
  </footer>
  <script is:inline>
    (function() {
      var btn = document.getElementById('theme-toggle');
      var sun = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');
      var html = document.documentElement;

      function update() {
        var isLight = html.classList.contains('light');
        sun.classList.toggle('hidden', isLight);
        moon.classList.toggle('hidden', !isLight);
      }

      update();

      btn.addEventListener('click', function() {
        var isLight = html.classList.contains('light');
        if (isLight) {
          html.classList.replace('light', 'dark');
          localStorage.setItem('almanac-theme', 'dark');
        } else {
          html.classList.replace('dark', 'light');
          localStorage.setItem('almanac-theme', 'light');
        }
        update();
      });
    })();
  </script>
</body>
</html>
