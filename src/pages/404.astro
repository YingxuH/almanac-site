---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Almanac">
  <section class="max-w-2xl mx-auto px-6 py-32 text-center">
    <div class="text-8xl font-bold font-mono text-almanac-accent/20 mb-4">404</div>
    <h1 class="text-2xl font-bold mb-3" data-en="This forecast hasn't been written yet." data-zh="这份预测尚未撰写。">This forecast hasn't been written yet.</h1>
    <p class="text-almanac-muted mb-8" data-en="The page you're looking for doesn't exist — but we're updating the future daily." data-zh="你找的页面不存在 — 但我们每天都在更新未来。">The page you're looking for doesn't exist — but we're updating the future daily.</p>
    <a href="/almanac-site/" class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all" data-en="Back to the present →" data-zh="回到现在 →">
      Back to the present &rarr;
    </a>
  </section>
</Base>
