---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Almanac">
  <section class="max-w-2xl mx-auto px-6 py-32 text-center">
    <div class="text-8xl font-bold font-mono text-almanac-accent/20 mb-4">404</div>
    <h1 class="text-2xl font-bold mb-3">This forecast hasn't been written yet.</h1>
    <p class="text-almanac-muted mb-8">The page you're looking for doesn't exist — but we're updating the future daily.</p>
    <a href="/almanac-site/" class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all">
      Back to the present &rarr;
    </a>
  </section>
</Base>
