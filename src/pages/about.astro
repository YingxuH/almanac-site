---
import Base from '../layouts/Base.astro';
import FadeIn from '../components/FadeIn.astro';
import BayesCalculator from '../components/BayesCalculator.astro';
---
<Base title="About — Almanac">

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <FadeIn>
      <h1 class="text-4xl font-bold mb-4" data-en="About Almanac" data-zh="关于 Almanac">About Almanac</h1>
      <p class="text-xl text-almanac-muted leading-relaxed max-w-2xl" data-en="We're cartographers, not prophets. We map the territory of possible futures with no stake in which one arrives." data-zh="我们是制图者，不是预言家。我们绘制可能的未来版图，对哪个会到来不持立场。">
        We're cartographers, not prophets. We map the territory of possible futures with no stake in which one arrives.
      </p>
    </FadeIn>

    <!-- What we do -->
    <FadeIn delay={100}>
      <div class="mt-12 space-y-6">
        <div class="p-6 rounded-xl border border-almanac-border bg-almanac-surface">
          <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
            <span class="w-1.5 h-6 rounded-full bg-almanac-accent"></span>
            <span data-en="What This Is" data-zh="这是什么">What This Is</span>
          </h2>
          <p class="text-almanac-muted leading-relaxed" data-en="Almanac is an AI-powered forecasting system that tracks how software engineering is changing over the next 3-30 years. Every day, our pipeline scrapes 17+ data sources, filters hundreds of signals through tiered AI models, and produces a confidence-scored forecast. We track 50 specific, falsifiable predictions and update them daily using Bayesian likelihood ratio analysis with a 5-persona forecaster panel." data-zh="Almanac 是一个 AI 驱动的预测系统，追踪软件工程在未来 3-30 年内的变化。每天，我们的流水线从 17+ 个数据源抓取数据，通过分层 AI 模型筛选数百个信号，并生成置信度评分预测。我们追踪 50 个具体的、可证伪的预测，并使用贝叶斯似然比分析和 5 人预测员面板每日更新。">
            Almanac is an AI-powered forecasting system that tracks how software engineering is changing over the next 3-30 years.
            Every day, our pipeline scrapes 17+ data sources, filters hundreds of signals through tiered AI models, and produces
            a confidence-scored forecast. We track 50 specific, falsifiable predictions and update them daily using Bayesian likelihood ratio analysis with a 5-persona forecaster panel.
          </p>
        </div>

        <div class="p-6 rounded-xl border border-almanac-border bg-almanac-surface">
          <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
            <span class="w-1.5 h-6 rounded-full bg-almanac-amber"></span>
            <span data-en="What This Is Not" data-zh="这不是什么">What This Is Not</span>
          </h2>
          <p class="text-almanac-muted leading-relaxed" data-en="We are not an oracle. We are not financial advisors. Our predictions are probabilistic estimates based on available evidence, and they are frequently wrong. The value isn't in any single prediction being correct — it's in the discipline of tracking, updating, and honestly reporting our accuracy over time." data-zh="我们不是神谕，也不是财务顾问。我们的预测是基于现有证据的概率估计，且经常出错。价值不在于某个预测是否正确，而在于追踪、更新并诚实报告我们准确性的这种纪律。">
            We are not an oracle. We are not financial advisors. Our predictions are probabilistic estimates based on available
            evidence, and they are frequently wrong. The value isn't in any single prediction being correct — it's in the
            discipline of tracking, updating, and honestly reporting our accuracy over time.
          </p>
        </div>
      </div>
    </FadeIn>

    <!-- Methodology -->
    <FadeIn delay={200}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-8" data-en="Methodology" data-zh="方法论">Methodology</h2>

        <div class="relative">
          {/* Vertical connector */}
          <div class="absolute left-8 top-8 bottom-8 w-px bg-almanac-border hidden sm:block"></div>

          <div class="space-y-8">
            {[
              {
                num: "01",
                title: "Data Collection",
                titleZh: "数据采集",
                desc: "Every day at 06:00 UTC, automated scrapers collect data from 17+ sources: Hacker News, arXiv, 5 RSS feeds (TechCrunch, Ars Technica, MIT Tech Review, The Verge, Wired), GitHub Trending, Stack Overflow, Semantic Scholar, FRED economic data, SEC EDGAR filings, Reddit, Lobsters, investor relations feeds, and X/Twitter. This yields 500+ raw items per day.",
                descZh: "每天 06:00 UTC，自动爬虫从 17+ 个数据源收集数据：Hacker News、arXiv、5 个 RSS 源（TechCrunch、Ars Technica、MIT Tech Review、The Verge、Wired）、GitHub Trending、Stack Overflow、Semantic Scholar、FRED 经济数据、SEC EDGAR 公司文件、Reddit、Lobsters、投资者关系动态及 X/Twitter。每天产生 500+ 个原始条目。",
                color: "accent"
              },
              {
                num: "02",
                title: "Signal Filtering",
                titleZh: "信号筛选",
                desc: "The AI model evaluates each item for relevance to the future of software engineering (3-30 year horizon). Items scoring below 0.5 recency-adjusted relevance are discarded. Typically 20-30 signals survive filtering. Each signal is classified by type: AI coding, job market, skills, regulation, tooling, or paradigm.",
                descZh: "AI 模型评估每个条目与软件工程未来（3-30 年时间范围）的相关性。经时效性调整后相关性评分低于 0.5 的条目被丢弃。通常有 20-30 个信号通过筛选。每个信号按类型分类：AI 编码、就业市场、技能、法规、工具或范式。",
                color: "amber"
              },
              {
                num: "03",
                title: "Narrative Synthesis",
                titleZh: "叙事综合",
                desc: "The top signals are synthesized into a coherent daily narrative. The AI is provided with yesterday's executive summary for continuity. It identifies the day's most significant developments and explains their 3-30 year implications.",
                descZh: "将顶级信号综合成连贯的每日叙事。AI 被提供昨天的执行摘要以保持连贯性。它识别当天最重要的进展并解释其 3-30 年的影响。",
                color: "green"
              },
              {
                num: "04",
                title: "Prediction Update",
                titleZh: "预测更新",
                desc: "Each of our 50 standing predictions is evaluated against the day's evidence via Bayesian likelihood ratio analysis. A 5-persona forecaster panel votes independently. Confidence can move up to +/-5 percentage points per day. All movements are logged with evidence trails.",
                descZh: "我们的 50 个持续预测中的每一个都会通过贝叶斯似然比分析根据当天的证据进行评估。5 人预测面板独立投票。置信度每天最多可变动 +/-5 个百分点。所有变动都记录了证据链。",
                color: "accent"
              },
              {
                num: "05",
                title: "Publication",
                titleZh: "发布",
                desc: "The report is committed to our private repository (with prediction deltas in the commit message), then pushed to the public site. The entire pipeline runs in under 10 minutes. Every report is timestamped and immutable.",
                descZh: "报告提交到我们的私有仓库（提交信息中包含预测变化），然后推送到公开网站。整个流水线在 10 分钟内运行完成。每份报告都有时间戳且不可篡改。",
                color: "green"
              },
            ].map((step) => {
              const cm = { accent: "text-almanac-accent", amber: "text-almanac-amber", green: "text-almanac-green" } as any;
              return (
                <div class="relative sm:pl-20">
                  <div class={`hidden sm:flex absolute left-[18px] top-2 w-8 h-8 rounded-lg border border-almanac-border bg-almanac-surface items-center justify-center text-xs font-bold font-mono ${cm[step.color]}`}>
                    {step.num}
                  </div>
                  <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface/50">
                    <div class="flex items-center gap-2 mb-2">
                      <span class={`sm:hidden text-sm font-bold font-mono ${cm[step.color]}`}>{step.num}</span>
                      <h3 class="font-semibold" data-en={step.title} data-zh={step.titleZh}>{step.title}</h3>
                    </div>
                    <p class="text-sm text-almanac-muted leading-relaxed" data-en={step.desc} data-zh={step.descZh}>{step.desc}</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </FadeIn>

    <!-- The 5 Forecaster Personas -->
    <FadeIn delay={250}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-3" data-en="The 5 Forecaster Personas" data-zh="5位预测角色">The 5 Forecaster Personas</h2>
        <p class="text-sm text-almanac-muted mb-6" data-en="Each prediction is independently evaluated by 5 AI personas with different worldviews. The median likelihood ratio is used — no single perspective dominates." data-zh="每项预测由5个不同世界观的AI角色独立评估。使用中位似然比——没有单一视角主导。">
          Each prediction is independently evaluated by 5 AI personas with different worldviews. The median likelihood ratio is used — no single perspective dominates.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {[
            { name: "Techno-Optimist", nameZh: "技术乐观派", icon: "🚀", desc: "Believes AI will accelerate everything. Weights positive adoption signals heavily.", descZh: "相信AI将加速一切。高度重视积极的采用信号。", color: "green" },
            { name: "Labor Economist", nameZh: "劳动经济学家", icon: "📊", desc: "Focuses on employment data, wage trends, historical automation parallels.", descZh: "关注就业数据、薪资趋势和历史自动化类比。", color: "amber" },
            { name: "Security Hawk", nameZh: "安全鹰派", icon: "🛡", desc: "Highlights risks, vulnerabilities, and regulatory responses to AI-generated code.", descZh: "强调AI生成代码的风险、漏洞和监管应对。", color: "red" },
            { name: "Contrarian", nameZh: "逆向思考者", icon: "⚡", desc: "Systematically challenges consensus. Asks 'what if the opposite happens?'", descZh: "系统性地挑战共识。追问'如果相反的情况发生呢？'", color: "accent" },
            { name: "Base Rate Empiricist", nameZh: "基准率经验主义者", icon: "📈", desc: "Anchors on historical base rates. Skeptical of 'this time is different' narratives.", descZh: "以历史基准率为锚点。对'这次不同'的叙事持怀疑态度。", color: "muted" },
          ].map((p) => {
            const cm = { green: "border-almanac-green/30 bg-almanac-green/5", amber: "border-almanac-amber/30 bg-almanac-amber/5", red: "border-almanac-red/30 bg-almanac-red/5", accent: "border-almanac-accent/30 bg-almanac-accent/5", muted: "border-almanac-border bg-almanac-surface" } as any;
            return (
              <div class={`p-4 rounded-xl border ${cm[p.color]}`}>
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-lg">{p.icon}</span>
                  <h3 class="font-semibold text-sm" data-en={p.name} data-zh={p.nameZh}>{p.name}</h3>
                </div>
                <p class="text-xs text-almanac-muted leading-relaxed" data-en={p.desc} data-zh={p.descZh}>{p.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </FadeIn>

    <!-- Why These Parameters -->
    <FadeIn delay={300}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-3" data-en="Design Decisions" data-zh="设计决策">Design Decisions</h2>
        <p class="text-sm text-almanac-muted mb-6" data-en="The numbers behind our methodology aren't arbitrary — here's why we chose them." data-zh="方法论背后的数字不是随意选择的——以下是我们选择它们的原因。">
          The numbers behind our methodology aren't arbitrary — here's why we chose them.
        </p>
        <div class="space-y-4">
          {[
            { param: "0.3 dampening", paramZh: "0.3 阻尼系数", why: "At 1.0, a single day's evidence from a noisy source causes multi-percentage-point swings that reverse the next day. At 0.3, it takes consistent evidence across several days to meaningfully shift a prediction — which matches how real-world trends work.", whyZh: "阻尼系数为1.0时，来自噪声源的单日证据会导致多个百分点的波动，第二天又反转。0.3时，需要连续多天的一致证据才能显著移动预测——这与现实世界趋势的运作方式一致。" },
            { param: "5pp max daily move", paramZh: "每日最大5pp变动", why: "Prevents overreaction to single events. Even genuinely significant developments (a major acquisition, a breakthrough paper) need time for second-order effects to become clear. Big shifts should accumulate over weeks, not happen overnight.", whyZh: "防止对单一事件的过度反应。即使是真正重大的发展（大型收购、突破性论文），也需要时间让二阶效应变得清晰。重大变化应该在数周内累积，而不是一夜之间发生。" },
            { param: "5 personas, median LR", paramZh: "5个角色，中位LR", why: "Using the median (not mean) of 5 likelihood ratios is robust to outlier personas. If the Techno-Optimist gives LR=5.0 and everyone else gives ~1.0, the median ignores the outlier. This prevents any single worldview from dominating.", whyZh: "使用5个似然比的中位数（而非均值）可以抵抗异常角色。如果技术乐观派给出LR=5.0而其他人给~1.0，中位数会忽略异常值。这防止任何单一世界观主导结果。" },
            { param: "[3%, 97%] bounds", paramZh: "[3%, 97%] 边界", why: "Nothing is ever truly 0% or 100% — there's always a chance we're wrong about the question itself, or the world changes in ways nobody predicted. Hard bounds acknowledge irreducible uncertainty.", whyZh: "没有什么是真正的0%或100%——总是有可能我们对问题本身的理解有误，或者世界以无人预测的方式变化。硬边界承认了不可消除的不确定性。" },
          ].map((d) => (
            <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface/50">
              <div class="text-sm font-bold font-mono text-almanac-accent mb-1" data-en={d.param} data-zh={d.paramZh}>{d.param}</div>
              <p class="text-xs text-almanac-muted leading-relaxed" data-en={d.why} data-zh={d.whyZh}>{d.why}</p>
            </div>
          ))}
        </div>
      </div>
    </FadeIn>

    <!-- Bayesian Calculator -->
    <FadeIn delay={325}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-3" data-en="Try the Formula Yourself" data-zh="亲自尝试公式">Try the Formula Yourself</h2>
        <p class="text-sm text-almanac-muted mb-6" data-en="This calculator runs the exact same Bayesian update formula our pipeline uses every day. Use the presets to see how source credibility and evidence strength interact." data-zh="此计算器使用我们流水线每天运行的完全相同的贝叶斯更新公式。使用预设按钮查看来源可信度和证据强度如何相互作用。">
          This calculator runs the exact same Bayesian update formula our pipeline uses every day. Use the presets to see how source credibility and evidence strength interact.
        </p>
        <BayesCalculator />
      </div>
    </FadeIn>

    <!-- Confidence scores explained -->
    <FadeIn delay={350}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-6" data-en="Reading Confidence Scores" data-zh="解读置信度评分">Reading Confidence Scores</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="p-4 rounded-lg border border-almanac-green/20 bg-almanac-green/5">
            <div class="text-2xl font-bold font-mono text-almanac-green mb-1">75-100%</div>
            <div class="text-sm font-medium mb-1" data-en="High Confidence" data-zh="高置信度">High Confidence</div>
            <p class="text-xs text-almanac-muted" data-en="Strong evidence base, clear trend direction. We'd be surprised if this doesn't happen." data-zh="强有力的证据基础，明确的趋势方向。如果这不发生，我们会感到惊讶。">Strong evidence base, clear trend direction. We'd be surprised if this doesn't happen.</p>
          </div>
          <div class="p-4 rounded-lg border border-almanac-amber/20 bg-almanac-amber/5">
            <div class="text-2xl font-bold font-mono text-almanac-amber mb-1">60-74%</div>
            <div class="text-sm font-medium mb-1" data-en="Moderate Confidence" data-zh="中等置信度">Moderate Confidence</div>
            <p class="text-xs text-almanac-muted" data-en="Good evidence but significant uncertainty remains. Could go either way with new developments." data-zh="有较好的证据，但仍存在显著的不确定性。随着新进展，可能朝任何方向发展。">Good evidence but significant uncertainty remains. Could go either way with new developments.</p>
          </div>
          <div class="p-4 rounded-lg border border-almanac-red/20 bg-almanac-red/5">
            <div class="text-2xl font-bold font-mono text-almanac-red mb-1">40-59%</div>
            <div class="text-sm font-medium mb-1" data-en="Low Confidence" data-zh="低置信度">Low Confidence</div>
            <p class="text-xs text-almanac-muted" data-en="Genuinely uncertain. Included because the question matters, not because we're confident." data-zh="真正不确定。纳入是因为问题重要，而不是因为我们有把握。">Genuinely uncertain. Included because the question matters, not because we're confident.</p>
          </div>
          <div class="p-4 rounded-lg border border-almanac-border">
            <div class="text-2xl font-bold font-mono text-almanac-muted mb-1">+/-5/day</div>
            <div class="text-sm font-medium mb-1" data-en="Max Daily Movement" data-zh="每日最大变动">Max Daily Movement</div>
            <p class="text-xs text-almanac-muted" data-en="Confidence scores are clamped to prevent overreaction to single-day signals. Big shifts accumulate over weeks." data-zh="置信度评分被限制，以防止对单日信号的过度反应。重大变化在数周内累积。">Confidence scores are clamped to prevent overreaction to single-day signals. Big shifts accumulate over weeks.</p>
          </div>
        </div>
      </div>
    </FadeIn>

    <!-- Tech stack -->
    <FadeIn delay={400}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-6" data-en="Tech Stack" data-zh="技术栈">Tech Stack</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {[
            { name: "Python 3.12", role: "Pipeline", roleZh: "流水线" },
            { name: "Gemini 3.1 Pro", role: "Primary LLM", roleZh: "主要 LLM" },
            { name: "Gemini 2.5 Flash", role: "Fallback LLM", roleZh: "备用 LLM" },
            { name: "litellm", role: "LLM Routing", roleZh: "LLM 路由" },
            { name: "Astro 6", role: "Website", roleZh: "网站" },
            { name: "Tailwind 4", role: "Styling", roleZh: "样式" },
            { name: "GitHub Actions", role: "Daily Cron", roleZh: "每日定时" },
            { name: "GitHub Pages", role: "Hosting", roleZh: "托管" },
          ].map(t => (
            <div class="p-3 rounded-lg border border-almanac-border bg-almanac-surface text-center hover:border-almanac-accent/30 transition-colors">
              <div class="text-sm font-semibold">{t.name}</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider mt-0.5" data-en={t.role} data-zh={t.roleZh}>{t.role}</div>
            </div>
          ))}
        </div>
      </div>
    </FadeIn>

    <!-- Open source -->
    <FadeIn delay={500}>
      <div class="mt-16 p-8 rounded-xl border border-almanac-accent/20 bg-almanac-accent/5 text-center">
        <h2 class="text-2xl font-bold mb-3" data-en="Open Source" data-zh="开源">Open Source</h2>
        <p class="text-almanac-muted mb-6 max-w-lg mx-auto" data-en="The website frontend is open source. The forecasting pipeline methodology, predictions, and accuracy record are all published publicly so you can evaluate our work without needing the code." data-zh="网站前端是开源的。预测流水线的方法论、预测和准确性记录都公开发布，让您无需查看代码即可评估我们的工作。">
          The website frontend is open source. The forecasting pipeline methodology,
          predictions, and accuracy record are all published publicly so you can evaluate our work without needing the code.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="https://github.com/YingxuH/almanac-site" class="inline-flex px-5 py-2.5 border border-almanac-accent/30 rounded-lg text-almanac-accent hover:bg-almanac-accent/10 transition-colors font-medium text-sm" data-en="View Site Source →" data-zh="查看网站源码 →">
            View Site Source &rarr;
          </a>
          <a href="https://github.com/YingxuH/almanac" class="inline-flex px-5 py-2.5 border border-almanac-border rounded-lg text-almanac-muted hover:text-almanac-text hover:border-almanac-muted transition-colors font-medium text-sm" data-en="View Pipeline →" data-zh="查看流水线 →">
            View Pipeline &rarr;
          </a>
        </div>
      </div>
    </FadeIn>

  </section>

</Base>
