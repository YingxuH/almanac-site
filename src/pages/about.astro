---
import Base from '../layouts/Base.astro';
import FadeIn from '../components/FadeIn.astro';
import BayesCalculator from '../components/BayesCalculator.astro';
import { loadPredictions } from '../lib/data';
const totalPreds = loadPredictions().length;
---
<Base title="About — Almanac">

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <FadeIn>
      <h1 class="text-4xl font-bold mb-4" data-en="About Almanac" data-zh="关于 Almanac">About Almanac</h1>
      <p class="text-xl text-almanac-muted leading-relaxed max-w-2xl" data-en="We're cartographers, not prophets. We map the territory of possible futures with no stake in which one arrives." data-zh="我们画地图，不算命。把可能的未来版图摊开来看，至于哪条路真的走通，我们不押注。">
        We're cartographers, not prophets. We map the territory of possible futures with no stake in which one arrives.
      </p>
    </FadeIn>

    <!-- What we do -->
    <FadeIn delay={100}>
      <div class="mt-12 space-y-6">
        <div class="p-6 rounded-xl border border-almanac-border bg-almanac-surface">
          <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
            <span class="w-1.5 h-6 rounded-full bg-almanac-accent"></span>
            <span data-en="What This Is" data-zh="这东西是干嘛的">What This Is</span>
          </h2>
          <p class="text-almanac-muted leading-relaxed" data-en={`Almanac is an AI-powered forecasting system that tracks how software engineering is changing over the next 3-30 years. Every day, our pipeline scrapes 17+ data sources, filters hundreds of signals through tiered AI models, and produces a confidence-scored forecast. We track ${totalPreds} specific, falsifiable predictions and update them daily using Bayesian likelihood ratio analysis with a 10-persona forecaster panel.`} data-zh={`Almanac 是一套大模型驱动的预测系统，专门追踪软件工程在未来 3—30 年的走向。每天流水线自动爬取 17+ 个数据源，用分层大模型从数百条信号里筛出有价值的东西，输出带置信度的预测。我们维护 ${totalPreds} 条具体、可证伪的预测，每天用 Bayesian 似然比分析 + 5 人角色面板同步更新。`}>
            Almanac is an AI-powered forecasting system that tracks how software engineering is changing over the next 3-30 years.
            Every day, our pipeline scrapes 17+ data sources, filters hundreds of signals through tiered AI models, and produces
            a confidence-scored forecast. We track {totalPreds} specific, falsifiable predictions and update them daily using Bayesian likelihood ratio analysis with a 10-persona forecaster panel.
          </p>
        </div>

        <div class="p-6 rounded-xl border border-almanac-border bg-almanac-surface">
          <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
            <span class="w-1.5 h-6 rounded-full bg-almanac-amber"></span>
            <span data-en="What This Is Not" data-zh="这不是什么">What This Is Not</span>
          </h2>
          <p class="text-almanac-muted leading-relaxed" data-en="We are not an oracle. We are not financial advisors. Our predictions are probabilistic estimates based on available evidence, and they are frequently wrong. The value isn't in any single prediction being correct — it's in the discipline of tracking, updating, and honestly reporting our accuracy over time." data-zh="我们不是神算子，也不提供投资建议。预测本质上是基于现有证据的概率估计，会经常出错。这东西的价值不在于某条预测灵不灵，而在于持续追踪、持续更新、把失误也公开摆出来——这套纪律本身才是核心。">
            We are not an oracle. We are not financial advisors. Our predictions are probabilistic estimates based on available
            evidence, and they are frequently wrong. The value isn't in any single prediction being correct — it's in the
            discipline of tracking, updating, and honestly reporting our accuracy over time.
          </p>
        </div>

        <!-- How we're different -->
        <div class="p-6 rounded-xl border border-almanac-accent/20 bg-almanac-accent/5">
          <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
            <span class="w-1.5 h-6 rounded-full bg-almanac-accent"></span>
            <span data-en="How We're Different" data-zh="跟其他产品有什么区别">How We're Different</span>
          </h2>
          <div class="grid sm:grid-cols-3 gap-3 text-xs">
            <div class="p-3 rounded-lg bg-almanac-bg/50">
              <div class="font-semibold text-sm mb-1">Almanac</div>
              <ul class="text-almanac-muted space-y-1">
                <li data-en={`${totalPreds} SWE-specific predictions`} data-zh={`${totalPreds}条软件工程专属预测`}>{totalPreds} SWE-specific predictions</li>
                <li data-en="Daily automated Bayesian updates" data-zh="每日自动 Bayesian 更新">Daily automated Bayesian updates</li>
                <li data-en="10-persona panel with evidence trails" data-zh="10角色面板 + 完整证据链">10-persona panel with evidence trails</li>
                <li data-en="Free, open methodology" data-zh="免费，方法论完全公开">Free, open methodology</li>
              </ul>
            </div>
            <div class="p-3 rounded-lg bg-almanac-bg/50">
              <div class="font-semibold text-sm mb-1 text-almanac-muted">Metaculus</div>
              <ul class="text-almanac-muted space-y-1">
                <li data-en="Broad topics (not SWE-focused)" data-zh="话题广泛，不专注软件工程">Broad topics (not SWE-focused)</li>
                <li data-en="Crowd-sourced human forecasters" data-zh="真人众包预测">Crowd-sourced human forecasters</li>
                <li data-en="Large resolved question library" data-zh="已有大量已验证历史题库">Large resolved question library</li>
                <li data-en="Free, community-driven" data-zh="免费，社区驱动">Free, community-driven</li>
              </ul>
            </div>
            <div class="p-3 rounded-lg bg-almanac-bg/50">
              <div class="font-semibold text-sm mb-1 text-almanac-muted">Polymarket</div>
              <ul class="text-almanac-muted space-y-1">
                <li data-en="Financial prediction markets" data-zh="真钱下注的预测市场">Financial prediction markets</li>
                <li data-en="Real money at stake" data-zh="输赢见真章">Real money at stake</li>
                <li data-en="Mostly politics/crypto/events" data-zh="以政治/加密/突发事件为主">Mostly politics/crypto/events</li>
                <li data-en="Not SWE career-focused" data-zh="不关注软件工程职业">Not SWE career-focused</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </FadeIn>

    <!-- Methodology -->
    <FadeIn delay={200}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-8" data-en="Methodology" data-zh="怎么跑的">Methodology</h2>

        <div class="relative">
          {/* Vertical connector */}
          <div class="absolute left-8 top-8 bottom-8 w-px bg-almanac-border hidden sm:block"></div>

          <div class="space-y-8">
            {[
              {
                num: "01",
                title: "Data Collection",
                titleZh: "数据采集",
                desc: "Every day at 06:00 UTC, automated scrapers collect data from 17+ sources: Hacker News, arXiv, 5 RSS feeds (TechCrunch, Ars Technica, MIT Tech Review, The Verge, Wired), GitHub Trending, Stack Overflow, Semantic Scholar, FRED economic data, SEC EDGAR filings, Reddit, Lobsters, investor relations feeds, and X/Twitter. This yields 500+ raw items per day.",
                descZh: "每天 06:00 UTC，爬虫自动跑完 17+ 个数据源：Hacker News、arXiv、5 个 RSS（TechCrunch、Ars Technica、MIT Tech Review、The Verge、Wired）、GitHub Trending、Stack Overflow、Semantic Scholar、FRED 经济数据、SEC EDGAR 披露文件、Reddit、Lobsters、投资者关系动态和 X/Twitter。每天原始条目 500+。",
                color: "accent"
              },
              {
                num: "02",
                title: "Signal Filtering",
                titleZh: "信号筛选",
                desc: "The AI model evaluates each item for relevance to the future of software engineering (3-30 year horizon). Items scoring below 0.5 recency-adjusted relevance are discarded. Typically 20-30 signals survive filtering. Each signal is classified by type: AI coding, job market, skills, regulation, tooling, or paradigm.",
                descZh: "大模型逐条评估与软件工程未来走向（3—30 年视野）的相关性。时效性加权后低于 0.5 的直接丢掉。最终通常有 20—30 条信号留下来，按类型打标：AI 编程、就业市场、技能、监管、工具链或范式转变。",
                color: "amber"
              },
              {
                num: "03",
                title: "Narrative Synthesis",
                titleZh: "叙事综合",
                desc: "The top signals are synthesized into a coherent daily narrative. The AI is provided with yesterday's executive summary for continuity. It identifies the day's most significant developments and explains their 3-30 year implications.",
                descZh: "把筛选出的信号整合成连贯的每日报告。大模型拿到昨天的摘要作为上下文，找出当天最值得关注的进展，并分析其 3—30 年的长期含义。",
                color: "green"
              },
              {
                num: "04",
                title: "Prediction Update",
                titleZh: "预测更新",
                desc: `Each of our ${totalPreds} standing predictions is evaluated against the day's evidence via Bayesian likelihood ratio analysis. A 10-persona forecaster panel votes independently. Confidence can move up to +/-5 percentage points per day. All movements are logged with evidence trails.`,
                descZh: `${totalPreds} 条在跑预测逐一用 Bayesian 似然比分析对照当天证据。5 个角色独立投票，互不干扰。置信度单日最多动 +/-5 个百分点，每次变动都有证据链存档。`,
                color: "accent"
              },
              {
                num: "05",
                title: "Publication",
                titleZh: "发布",
                desc: "The report is committed to our private repository (with prediction deltas in the commit message), then pushed to the public site. The entire pipeline runs in under 10 minutes. Every report is timestamped and immutable.",
                descZh: "报告 commit 到私有仓库（commit message 里带预测变动幅度），然后推送到公开网站。整条流水线 10 分钟内跑完。每份报告带时间戳，上链后不可改动。",
                color: "green"
              },
            ].map((step) => {
              const cm = { accent: "text-almanac-accent", amber: "text-almanac-amber", green: "text-almanac-green" } as any;
              return (
                <div class="relative sm:pl-20">
                  <div class={`hidden sm:flex absolute left-[18px] top-2 w-8 h-8 rounded-lg border border-almanac-border bg-almanac-surface items-center justify-center text-xs font-bold font-mono ${cm[step.color]}`}>
                    {step.num}
                  </div>
                  <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface/50">
                    <div class="flex items-center gap-2 mb-2">
                      <span class={`sm:hidden text-sm font-bold font-mono ${cm[step.color]}`}>{step.num}</span>
                      <h3 class="font-semibold" data-en={step.title} data-zh={step.titleZh}>{step.title}</h3>
                    </div>
                    <p class="text-sm text-almanac-muted leading-relaxed" data-en={step.desc} data-zh={step.descZh}>{step.desc}</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </FadeIn>

    <!-- The 10 Forecaster Personas -->
    <FadeIn delay={250}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-3" data-en="The 10 Forecaster Personas" data-zh="10 个预测角色">The 10 Forecaster Personas</h2>
        <p class="text-sm text-almanac-muted mb-6" data-en="Each prediction is independently evaluated by 10 AI personas with different worldviews. The median likelihood ratio is used — no single perspective dominates." data-zh="每条预测由 10 个世界观各异的大模型角色独立评估，取中位似然比——任何单一视角都不能一手遮天。">
          Each prediction is independently evaluated by 10 AI personas with different worldviews. The median likelihood ratio is used — no single perspective dominates.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {[
            { name: "Techno-Optimist", nameZh: "技术乐观派", icon: "🚀", desc: "Believes AI will accelerate everything. Weights positive adoption signals heavily.", descZh: "坚信 AI 会加速一切。对积极的采用信号给高权重。", color: "green" },
            { name: "Labor Economist", nameZh: "劳动经济学家", icon: "📊", desc: "Focuses on employment data, wage trends, historical automation parallels.", descZh: "盯着就业数据、薪资走势和历史上自动化浪潮的先例。", color: "amber" },
            { name: "Security Hawk", nameZh: "安全鹰派", icon: "🛡", desc: "Highlights risks, vulnerabilities, and regulatory responses to AI-generated code.", descZh: "专门挑 AI 生成代码的毛病：漏洞、风险、监管反弹。", color: "red" },
            { name: "Contrarian", nameZh: "杠精", icon: "⚡", desc: "Systematically challenges consensus. Asks 'what if the opposite happens?'", descZh: "系统性地跟共识对着干，专问「要是反过来呢？」", color: "accent" },
            { name: "Base Rate Empiricist", nameZh: "基率经验派", icon: "📈", desc: "Anchors on historical base rates. Skeptical of 'this time is different' narratives.", descZh: "死扣历史基准率，对「这次不一样」的说法一律保持怀疑。", color: "muted" },
            { name: "Startup Founder", nameZh: "创业者视角", icon: "💡", desc: "Bullish on disruption speed. Weights funding/valuation signals. Believes incumbents are slow.", descZh: "看好颠覆速度，重视融资/估值信号，觉得大公司总是慢半拍。", color: "green" },
            { name: "Enterprise Architect", nameZh: "企业架构师", icon: "🏢", desc: "Conservative on adoption timelines. Knows procurement cycles take 18-24 months. Demo ≠ deployed.", descZh: "对企业采用时间线保守。采购周期18-24个月，Demo ≠ 落地。", color: "amber" },
            { name: "Open Source Advocate", nameZh: "开源倡导者", icon: "🌐", desc: "Bullish on community-driven development. Believes open-source always wins long-term.", descZh: "看好社区驱动开发。长期来看开源总是赢家——生态效应和开发者偏好决定一切。", color: "accent" },
            { name: "Regulatory Watcher", nameZh: "监管观察者", icon: "⚖️", desc: "Believes regulation is coming faster than industry expects. EU AI Act, liability trends.", descZh: "认为监管来得比行业预期更快。重点关注 EU AI Act、责任归属趋势。", color: "red" },
            { name: "Developer Educator", nameZh: "开发者教育者", icon: "🎓", desc: "Focused on skills, bootcamps, CS enrollment. Believes talent pipeline adapts faster than pessimists predict.", descZh: "关注技能培养、训练营、CS招生。相信人才管道的适应速度比悲观者预期的更快。", color: "muted" },
          ].map((p) => {
            const cm = { green: "border-almanac-green/30 bg-almanac-green/5", amber: "border-almanac-amber/30 bg-almanac-amber/5", red: "border-almanac-red/30 bg-almanac-red/5", accent: "border-almanac-accent/30 bg-almanac-accent/5", muted: "border-almanac-border bg-almanac-surface" } as any;
            return (
              <div class={`p-4 rounded-xl border ${cm[p.color]}`}>
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-lg">{p.icon}</span>
                  <h3 class="font-semibold text-sm" data-en={p.name} data-zh={p.nameZh}>{p.name}</h3>
                </div>
                <p class="text-xs text-almanac-muted leading-relaxed" data-en={p.desc} data-zh={p.descZh}>{p.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </FadeIn>

    <!-- Why These Parameters -->
    <FadeIn delay={300}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-3" data-en="Design Decisions" data-zh="参数是怎么定的">Design Decisions</h2>
        <p class="text-sm text-almanac-muted mb-6" data-en="The numbers behind our methodology aren't arbitrary — here's why we chose them." data-zh="方法论里的数字不是拍脑袋定的——这里解释每个参数背后的逻辑。">
          The numbers behind our methodology aren't arbitrary — here's why we chose them.
        </p>
        <div class="space-y-4">
          {[
            { param: "0.3 dampening", paramZh: "0.3 阻尼系数", why: "At 1.0, a single day's evidence from a noisy source causes multi-percentage-point swings that reverse the next day. At 0.3, it takes consistent evidence across several days to meaningfully shift a prediction — which matches how real-world trends work.", whyZh: "阻尼设成 1.0 的话，一个噪音来源的单日证据就能引发好几个百分点的震荡，第二天又打回来。0.3 的情况下，需要连续多天一致的证据才能让预测真正移动——这才符合真实趋势的运作规律。" },
            { param: "5pp max daily move", paramZh: "单日最大变动 5pp", why: "Prevents overreaction to single events. Even genuinely significant developments (a major acquisition, a breakthrough paper) need time for second-order effects to become clear. Big shifts should accumulate over weeks, not happen overnight.", whyZh: "防止对单一事件过激反应。就算是真正重大的消息（大并购、突破性论文），二阶效应也需要时间才能显现。大幅变化应该在数周内慢慢累积，而不是一夜剧变。" },
            { param: "5 personas, median LR", paramZh: "5 角色，取中位 LR", why: "Using the median (not mean) of 5 likelihood ratios is robust to outlier personas. If the Techno-Optimist gives LR=5.0 and everyone else gives ~1.0, the median ignores the outlier. This prevents any single worldview from dominating.", whyZh: "取 5 个 LR 的中位数（不是均值），天然抗极端值。技术乐观派给 LR=5.0，其他人都给 ~1.0，中位数直接把那个异常值无视掉——任何单一世界观都别想一手遮天。" },
            { param: "[3%, 97%] bounds", paramZh: "概率边界 [3%, 97%]", why: "Nothing is ever truly 0% or 100% — there's always a chance we're wrong about the question itself, or the world changes in ways nobody predicted. Hard bounds acknowledge irreducible uncertainty.", whyZh: "没有什么事是真正的 0% 或 100%——我们可能对问题本身的理解就有偏差，也可能世界会以所有人都没预料到的方式变化。硬边界是对不可消除的不确定性诚实地认账。" },
          ].map((d) => (
            <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface/50">
              <div class="text-sm font-bold font-mono text-almanac-accent mb-1" data-en={d.param} data-zh={d.paramZh}>{d.param}</div>
              <p class="text-xs text-almanac-muted leading-relaxed" data-en={d.why} data-zh={d.whyZh}>{d.why}</p>
            </div>
          ))}
        </div>
      </div>
    </FadeIn>

    <!-- Bayesian Calculator -->
    <FadeIn delay={325}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-3" data-en="Try the Formula Yourself" data-zh="自己算算看">Try the Formula Yourself</h2>
        <p class="text-sm text-almanac-muted mb-6" data-en="This calculator runs the exact same Bayesian update formula our pipeline uses every day. Use the presets to see how source credibility and evidence strength interact." data-zh="这个计算器用的是流水线每天跑的同一套 Bayesian 更新公式。点预设按钮，感受一下来源可信度和证据强度怎么互相影响。">
          This calculator runs the exact same Bayesian update formula our pipeline uses every day. Use the presets to see how source credibility and evidence strength interact.
        </p>
        <BayesCalculator />
      </div>
    </FadeIn>

    <!-- Confidence scores explained -->
    <FadeIn delay={350}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-6" data-en="Reading Confidence Scores" data-zh="置信度怎么看">Reading Confidence Scores</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="p-4 rounded-lg border border-almanac-green/20 bg-almanac-green/5">
            <div class="text-2xl font-bold font-mono text-almanac-green mb-1">75-100%</div>
            <div class="text-sm font-medium mb-1" data-en="High Confidence" data-zh="高置信度">High Confidence</div>
            <p class="text-xs text-almanac-muted" data-en="Strong evidence base, clear trend direction. We'd be surprised if this doesn't happen." data-zh="证据扎实，趋势方向清晰。要是没发生，我们会很意外。">Strong evidence base, clear trend direction. We'd be surprised if this doesn't happen.</p>
          </div>
          <div class="p-4 rounded-lg border border-almanac-amber/20 bg-almanac-amber/5">
            <div class="text-2xl font-bold font-mono text-almanac-amber mb-1">60-74%</div>
            <div class="text-sm font-medium mb-1" data-en="Moderate Confidence" data-zh="中等置信度">Moderate Confidence</div>
            <p class="text-xs text-almanac-muted" data-en="Good evidence but significant uncertainty remains. Could go either way with new developments." data-zh="有一定证据支撑，但不确定性依然很大。新进展一出来随时可能反转。">Good evidence but significant uncertainty remains. Could go either way with new developments.</p>
          </div>
          <div class="p-4 rounded-lg border border-almanac-red/20 bg-almanac-red/5">
            <div class="text-2xl font-bold font-mono text-almanac-red mb-1">40-59%</div>
            <div class="text-sm font-medium mb-1" data-en="Low Confidence" data-zh="低置信度">Low Confidence</div>
            <p class="text-xs text-almanac-muted" data-en="Genuinely uncertain. Included because the question matters, not because we're confident." data-zh="真的不确定。放进来是因为这个问题很重要，不是因为我们有把握。">Genuinely uncertain. Included because the question matters, not because we're confident.</p>
          </div>
          <div class="p-4 rounded-lg border border-almanac-border">
            <div class="text-2xl font-bold font-mono text-almanac-muted mb-1">+/-5/day</div>
            <div class="text-sm font-medium mb-1" data-en="Max Daily Movement" data-zh="单日最大变动">Max Daily Movement</div>
            <p class="text-xs text-almanac-muted" data-en="Confidence scores are clamped to prevent overreaction to single-day signals. Big shifts accumulate over weeks." data-zh="置信度有上限，防止对单日信号过激反应。大幅变化是在几周内慢慢积累出来的。">Confidence scores are clamped to prevent overreaction to single-day signals. Big shifts accumulate over weeks.</p>
          </div>
        </div>
      </div>
    </FadeIn>

    <!-- Tech stack -->
    <FadeIn delay={400}>
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-6" data-en="Tech Stack" data-zh="用了什么技术">Tech Stack</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {[
            { name: "Python 3.12", role: "Pipeline", roleZh: "流水线" },
            { name: "Gemini 3.1 Pro", role: "Primary LLM", roleZh: "主力大模型" },
            { name: "Gemini 2.5 Flash", role: "Fallback LLM", roleZh: "备用大模型" },
