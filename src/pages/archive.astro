---
import Base from '../layouts/Base.astro';
import FadeIn from '../components/FadeIn.astro';
import fs from 'node:fs';
import path from 'node:path';

// Load all reports
const reportsDir = path.resolve('./src/content/reports');
const files = fs.readdirSync(reportsDir).filter((f: string) => f.endsWith('.md')).sort().reverse();

const reports = files.map(f => {
  const date = f.replace('.md', '');
  const content = fs.readFileSync(path.join(reportsDir, f), 'utf-8');
  // Extract executive summary
  const summaryMatch = content.match(/### Executive Summary\s*\n([\s\S]*?)(?=\n###|\n---|\Z)/);
  const summary = summaryMatch ? summaryMatch[1].trim().slice(0, 250) + '...' : '';
  // Extract signal count from content
  const signalCount = (content.match(/\*\*\d+\./g) || []).length;
  // Day number
  const dayNum = files.length - files.indexOf(f);
  return { date, summary, signalCount, dayNum, file: f };
});
---
<Base title="Archive — Almanac">

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <FadeIn>
      <div class="mb-10">
        <h1 class="text-3xl font-bold mb-2">Forecast Archive</h1>
        <p class="text-almanac-muted">Every forecast since Day 1 — a timestamped record of how our understanding of the future has evolved.</p>
      </div>
    </FadeIn>

    <!-- Timeline -->
    <div class="relative">
      {/* Vertical line */}
      <div class="absolute left-6 top-0 bottom-0 w-px bg-almanac-border"></div>

      <div class="space-y-6">
        {reports.map((r, i) => (
          <FadeIn delay={i * 100}>
            <a href={`/almanac-site/forecast`} class="block group">
              <div class="relative pl-16">
                {/* Timeline dot */}
                <div class={`absolute left-[18px] top-4 w-4 h-4 rounded-full border-2 ${i === 0 ? 'border-almanac-accent bg-almanac-accent/20' : 'border-almanac-border bg-almanac-surface'} group-hover:border-almanac-accent group-hover:bg-almanac-accent/20 transition-colors`}>
                  {i === 0 && (
                    <span class="absolute inset-0 rounded-full animate-ping bg-almanac-accent/30"></span>
                  )}
                </div>

                <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface hover:border-almanac-accent/30 hover:shadow-[0_0_20px_rgba(34,211,238,0.05)] transition-all duration-300">
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-3">
                      <span class="font-mono text-sm text-almanac-accent">{r.date}</span>
                      <span class="text-[10px] px-2 py-0.5 rounded-full bg-almanac-border text-almanac-muted">Day {r.dayNum}</span>
                      {i === 0 && <span class="text-[10px] px-2 py-0.5 rounded-full bg-almanac-green/10 text-almanac-green border border-almanac-green/20">Latest</span>}
                    </div>
                    <span class="text-xs text-almanac-muted">{r.signalCount} signals</span>
                  </div>
                  <p class="text-sm text-almanac-muted leading-relaxed">{r.summary}</p>
                </div>
              </div>
            </a>
          </FadeIn>
        ))}
      </div>

      {/* Bottom cap */}
      <div class="relative pl-16 pt-6">
        <div class="absolute left-[20px] top-6 w-3 h-3 rounded-full bg-almanac-border"></div>
        <p class="text-xs text-almanac-muted italic">The almanac began recording on March 21, 2026.</p>
      </div>
    </div>
  </section>

</Base>
