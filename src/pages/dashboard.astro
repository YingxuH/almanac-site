---
import Base from '../layouts/Base.astro';
import FadeIn from '../components/FadeIn.astro';
import GlowCard from '../components/GlowCard.astro';

const predictions = [
  { id: 1, claim: ">50% Fortune 500 code AI-generated by 2028", confidence: 74, history: [62, 64, 65, 68, 68, 74], category: "AI Coding", horizon: "2028", delta: 6 },
  { id: 2, claim: "'Computer Programmer' title ceases by 2031", confidence: 77, history: [70, 71, 72, 74, 74, 77], category: "Labor", horizon: "2031", delta: 3 },
  { id: 3, claim: "AI-fluent engineers earn $40K+ more by 2029", confidence: 71, history: [68, 69, 70, 71, 71, 71], category: "Compensation", horizon: "2029", delta: 0 },
  { id: 4, claim: "Senior engineer shortage crisis by 2030-2032", confidence: 80, history: [72, 73, 74, 77, 77, 80], category: "Labor", horizon: "2030", delta: 3 },
  { id: 5, claim: "Multi-agent AI handles >30% QA by 2028", confidence: 76, history: [72, 73, 74, 76, 76, 76], category: "Automation", horizon: "2028", delta: 0 },
  { id: 6, claim: "Major AI code security breach before 2029", confidence: 72, history: [68, 69, 70, 72, 72, 72], category: "Security", horizon: "2029", delta: 0 },
  { id: 7, claim: "More time reviewing AI code than writing by 2032", confidence: 72, history: [65, 67, 68, 72, 72, 72], category: "Workflow", horizon: "2032", delta: 0 },
  { id: 8, claim: "'AI system judgment' most valuable skill by 2036", confidence: 82, history: [74, 75, 76, 78, 78, 82], category: "Skills", horizon: "2036", delta: 4 },
];

const categories = ["AI Coding", "Labor", "Compensation", "Automation", "Security", "Workflow", "Skills"];
const categoryColors: Record<string, string> = {
  "AI Coding": "#22d3ee", "Labor": "#34d399", "Compensation": "#fbbf24",
  "Automation": "#818cf8", "Security": "#f87171", "Workflow": "#fb923c", "Skills": "#a78bfa",
};

const avgConfidence = Math.round(predictions.reduce((a, p) => a + p.confidence, 0) / predictions.length);
const movedUp = predictions.filter(p => p.delta > 0).length;
const totalDelta = predictions.reduce((a, p) => a + p.delta, 0);

const signalsByType = [
  { type: "AI Coding", count: 8, pct: 33 },
  { type: "Job Market", count: 5, pct: 21 },
  { type: "Tooling", count: 4, pct: 17 },
  { type: "Security", count: 3, pct: 12 },
  { type: "Paradigm", count: 2, pct: 8 },
  { type: "Skills", count: 1, pct: 4 },
  { type: "Regulation", count: 1, pct: 4 },
];

const timelineEvents = [
  { date: "Mar 21", label: "Day 1 — First forecast", type: "launch" },
  { date: "Mar 22", label: "Day 2 — 10:1 architect ratio", type: "signal" },
];
---
<Base title="Dashboard — Almanac">

  <!-- Dashboard header -->
  <section class="border-b border-almanac-border bg-gradient-to-b from-almanac-accent/3 to-transparent">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-8 pb-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Dashboard</h1>
          <p class="text-sm text-almanac-muted mt-1">Overview of all tracked predictions and signals (updated daily)</p>
        </div>
        <div class="flex items-center gap-2 text-xs text-almanac-muted">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
          </span>
          Last updated: March 22, 2026
        </div>
      </div>

      <!-- KPI cards -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface/80 backdrop-blur-sm">
          <div class="text-xs text-almanac-muted uppercase tracking-wider mb-1">Avg Confidence</div>
          <div class="text-3xl font-bold font-mono text-almanac-accent">{avgConfidence}%</div>
          <div class="text-xs text-almanac-green mt-1">+{totalDelta}pp net today</div>
        </div>
        <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface/80 backdrop-blur-sm">
          <div class="text-xs text-almanac-muted uppercase tracking-wider mb-1">Predictions</div>
          <div class="text-3xl font-bold font-mono">{predictions.length}</div>
          <div class="text-xs text-almanac-green mt-1">{movedUp} moved up today</div>
        </div>
        <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface/80 backdrop-blur-sm">
          <div class="text-xs text-almanac-muted uppercase tracking-wider mb-1">Signals Today</div>
          <div class="text-3xl font-bold font-mono">24</div>
          <div class="text-xs text-almanac-muted mt-1">from 270 scraped</div>
        </div>
        <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface/80 backdrop-blur-sm">
          <div class="text-xs text-almanac-muted uppercase tracking-wider mb-1">Day</div>
          <div class="text-3xl font-bold font-mono">2</div>
          <div class="text-xs text-almanac-muted mt-1">consecutive forecasts</div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">

    <div class="grid lg:grid-cols-3 gap-6">

      <!-- Left column: Confidence heatmap + sparklines -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Confidence trend chart -->
        <FadeIn>
          <div class="rounded-xl border border-almanac-border bg-almanac-surface p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold">Confidence Trends</h3>
              <span class="text-xs text-almanac-muted font-mono">Last 6 data points</span>
            </div>
            <div class="space-y-4">
              {predictions.map(p => {
                const min = Math.min(...p.history);
                const max = Math.max(...p.history);
                const range = max - min || 1;
                const color = categoryColors[p.category] || "#22d3ee";
                return (
                  <div class="group">
                    <div class="flex items-center gap-3 mb-1.5">
                      <span class={`font-mono text-sm font-bold w-10 text-right ${p.delta > 0 ? 'text-almanac-green' : p.delta < 0 ? 'text-almanac-red' : 'text-almanac-muted'}`}>
                        {p.confidence}%
                      </span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                          <span class="text-xs truncate max-w-[300px]">{p.claim}</span>
                          {p.delta !== 0 && (
                            <span class={`text-[10px] font-mono px-1 py-0.5 rounded ${p.delta > 0 ? 'bg-almanac-green/10 text-almanac-green' : 'bg-almanac-red/10 text-almanac-red'}`}>
                              {p.delta > 0 ? '+' : ''}{p.delta}
                            </span>
                          )}
                        </div>
                      </div>
                      <!-- Sparkline SVG -->
                      <svg class="w-24 h-8 flex-shrink-0" viewBox="0 0 120 32">
                        <defs>
                          <linearGradient id={`grad-${p.id}`} x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color={color} stop-opacity="0.3"/>
                            <stop offset="100%" stop-color={color} stop-opacity="0"/>
                          </linearGradient>
                        </defs>
                        {/* Area fill */}
                        <path
                          d={`M0,${32 - ((p.history[0] - min) / range) * 28} ${p.history.map((v, i) => `L${i * 24},${32 - ((v - min) / range) * 28}`).join(' ')} L${(p.history.length - 1) * 24},32 L0,32 Z`}
                          fill={`url(#grad-${p.id})`}
                        />
                        {/* Line */}
                        <polyline
                          points={p.history.map((v, i) => `${i * 24},${32 - ((v - min) / range) * 28}`).join(' ')}
                          fill="none"
                          stroke={color}
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                        {/* Current value dot */}
                        <circle
                          cx={(p.history.length - 1) * 24}
                          cy={32 - ((p.history[p.history.length - 1] - min) / range) * 28}
                          r="3"
                          fill={color}
                          class="animate-pulse"
                        />
                      </svg>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </FadeIn>

        <!-- Signal distribution -->
        <FadeIn delay={100}>
          <div class="rounded-xl border border-almanac-border bg-almanac-surface p-5">
            <h3 class="font-semibold mb-4">Signal Distribution</h3>
            <div class="space-y-3">
              {signalsByType.map(s => (
                <div class="flex items-center gap-3">
                  <span class="text-xs text-almanac-muted w-20 text-right">{s.type}</span>
                  <div class="flex-1 h-6 rounded-md bg-almanac-border/50 overflow-hidden relative">
                    <div
                      class="h-full rounded-md bg-gradient-to-r from-almanac-accent to-almanac-accent/60 transition-all duration-1000 signal-bar"
                      style={`width: ${s.pct}%`}
                    />
                    <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[10px] font-mono text-almanac-text/70">{s.count}</span>
                  </div>
                  <span class="text-xs font-mono text-almanac-muted w-8">{s.pct}%</span>
                </div>
              ))}
            </div>
          </div>
        </FadeIn>

        <!-- Prediction heatmap grid -->
        <FadeIn delay={200}>
          <div class="rounded-xl border border-almanac-border bg-almanac-surface p-5">
            <h3 class="font-semibold mb-4">Confidence Heatmap</h3>
            <div class="grid grid-cols-4 gap-2">
              {predictions.map(p => {
                const hue = p.confidence >= 80 ? 'bg-almanac-green/20 border-almanac-green/30 text-almanac-green'
                  : p.confidence >= 75 ? 'bg-almanac-green/10 border-almanac-green/20 text-almanac-green'
                  : p.confidence >= 70 ? 'bg-almanac-amber/10 border-almanac-amber/20 text-almanac-amber'
                  : 'bg-almanac-red/10 border-almanac-red/20 text-almanac-red';
                return (
                  <div class={`p-3 rounded-lg border ${hue} text-center group hover:scale-105 transition-transform cursor-default`}>
                    <div class="text-2xl font-bold font-mono">{p.confidence}</div>
                    <div class="text-[9px] mt-1 text-almanac-muted leading-tight truncate">{p.category}</div>
                    {p.delta !== 0 && (
                      <div class={`text-[10px] font-mono mt-0.5 ${p.delta > 0 ? 'text-almanac-green' : 'text-almanac-red'}`}>
                        {p.delta > 0 ? '+' : ''}{p.delta}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        </FadeIn>
      </div>

      <!-- Right column: Activity feed + category breakdown -->
      <div class="space-y-6">

        <!-- Radar-style category chart -->
        <FadeIn>
          <div class="rounded-xl border border-almanac-border bg-almanac-surface p-5">
            <h3 class="font-semibold mb-4">Category Health</h3>
            <div class="relative w-full aspect-square max-w-[280px] mx-auto">
              <svg viewBox="0 0 200 200" class="w-full h-full">
                {/* Grid rings */}
                {[20, 40, 60, 80, 100].map(r => (
                  <circle cx="100" cy="100" r={r * 0.8} fill="none" stroke="var(--color-almanac-border)" stroke-width="0.5" opacity="0.5"/>
                ))}
                {/* Axis lines and labels */}
                {categories.map((cat, i) => {
                  const angle = (Math.PI * 2 * i) / categories.length - Math.PI / 2;
                  const x2 = 100 + Math.cos(angle) * 80;
                  const y2 = 100 + Math.sin(angle) * 80;
                  const labelX = 100 + Math.cos(angle) * 95;
                  const labelY = 100 + Math.sin(angle) * 95;
                  return (
                    <>
                      <line x1="100" y1="100" x2={x2} y2={y2} stroke="var(--color-almanac-border)" stroke-width="0.5" opacity="0.5"/>
                      <text x={labelX} y={labelY} text-anchor="middle" dominant-baseline="middle" fill="var(--color-almanac-muted)" font-size="6" font-family="var(--font-mono)">{cat.split(' ')[0]}</text>
                    </>
                  );
                })}
                {/* Data polygon */}
                <polygon
                  points={categories.map((cat, i) => {
                    const pred = predictions.find(p => p.category === cat);
                    const val = pred ? pred.confidence / 100 : 0;
                    const angle = (Math.PI * 2 * i) / categories.length - Math.PI / 2;
                    return `${100 + Math.cos(angle) * val * 80},${100 + Math.sin(angle) * val * 80}`;
                  }).join(' ')}
                  fill="var(--color-almanac-accent)"
                  fill-opacity="0.15"
                  stroke="var(--color-almanac-accent)"
                  stroke-width="1.5"
                />
                {/* Data points */}
                {categories.map((cat, i) => {
                  const pred = predictions.find(p => p.category === cat);
                  const val = pred ? pred.confidence / 100 : 0;
                  const angle = (Math.PI * 2 * i) / categories.length - Math.PI / 2;
                  return (
                    <circle
                      cx={100 + Math.cos(angle) * val * 80}
                      cy={100 + Math.sin(angle) * val * 80}
                      r="3"
                      fill="var(--color-almanac-accent)"
                    />
                  );
                })}
              </svg>
            </div>
          </div>
        </FadeIn>

        <!-- Activity timeline -->
        <FadeIn delay={100}>
          <div class="rounded-xl border border-almanac-border bg-almanac-surface p-5">
            <h3 class="font-semibold mb-4">Activity Log</h3>
            <div class="space-y-0">
              {[
                { time: "06:00", action: "Pipeline started", icon: "play", color: "accent" },
                { time: "06:01", action: "270 items scraped from 8 sources", icon: "download", color: "accent" },
                { time: "06:02", action: "24 signals filtered (Gemini 3.1 Pro)", icon: "filter", color: "amber" },
                { time: "06:03", action: "Report synthesized (9,132 chars)", icon: "doc", color: "green" },
                { time: "06:03", action: "P8 moved 78% → 82% (+4)", icon: "up", color: "green" },
                { time: "06:03", action: "P1 moved 68% → 74% (+6)", icon: "up", color: "green" },
                { time: "06:03", action: "P2 moved 74% → 77% (+3)", icon: "up", color: "green" },
                { time: "06:03", action: "P4 moved 77% → 80% (+3)", icon: "up", color: "green" },
                { time: "06:04", action: "Committed to almanac repo", icon: "git", color: "accent" },
                { time: "06:04", action: "Published to site", icon: "globe", color: "accent" },
                { time: "06:04", action: "Pipeline complete (1.8 min)", icon: "check", color: "green" },
              ].map((entry, i) => {
                const colorClass = entry.color === 'green' ? 'bg-almanac-green' : entry.color === 'amber' ? 'bg-almanac-amber' : 'bg-almanac-accent';
                return (
                  <div class="flex gap-3 group">
                    <div class="flex flex-col items-center">
                      <div class={`w-2 h-2 rounded-full ${colorClass} mt-2 group-hover:scale-150 transition-transform`}></div>
                      {i < 10 && <div class="w-px flex-1 bg-almanac-border"></div>}
                    </div>
                    <div class="pb-4 min-w-0">
                      <div class="flex items-center gap-2">
                        <span class="text-[10px] font-mono text-almanac-muted">{entry.time}</span>
                        <span class="text-xs text-almanac-muted">{entry.action}</span>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </FadeIn>

        <!-- Source health -->
        <FadeIn delay={200}>
          <div class="rounded-xl border border-almanac-border bg-almanac-surface p-5">
            <h3 class="font-semibold mb-4">Source Health</h3>
            <div class="space-y-2">
              {[
                { name: "Hacker News", items: 116, status: "ok" },
                { name: "arXiv", items: 90, status: "ok" },
                { name: "TechCrunch", items: 20, status: "ok" },
                { name: "Ars Technica", items: 20, status: "ok" },
                { name: "MIT Tech Review", items: 10, status: "ok" },
                { name: "The Verge", items: 5, status: "ok" },
                { name: "GitHub Trending", items: 9, status: "ok" },
                { name: "Stack Overflow", items: 0, status: "off" },
                { name: "Metaculus", items: 0, status: "off" },
              ].map(s => (
                <div class="flex items-center justify-between py-1.5 px-2 rounded-lg hover:bg-almanac-border/20 transition-colors">
                  <div class="flex items-center gap-2">
                    <span class={`w-1.5 h-1.5 rounded-full ${s.status === 'ok' ? 'bg-almanac-green' : 'bg-almanac-muted'}`}></span>
                    <span class="text-xs">{s.name}</span>
                  </div>
                  <span class="text-xs font-mono text-almanac-muted">{s.items > 0 ? s.items : '—'}</span>
                </div>
              ))}
            </div>
          </div>
        </FadeIn>
      </div>
    </div>
  </div>

</Base>
