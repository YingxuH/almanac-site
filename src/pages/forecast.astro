---
import Base from '../layouts/Base.astro';
import GlowCard from '../components/GlowCard.astro';
import FadeIn from '../components/FadeIn.astro';

import fs from 'node:fs';
import path from 'node:path';

// Load predictions to show "What Moved Today"
let allPredictions: any[] = [];
try {
  const predPath = path.resolve(process.cwd(), '..', 'data', 'predictions.json');
  allPredictions = JSON.parse(fs.readFileSync(predPath, 'utf-8'));
} catch {
  try {
    const altPath = path.resolve(process.cwd(), '..', '..', 'data', 'predictions.json');
    allPredictions = JSON.parse(fs.readFileSync(altPath, 'utf-8'));
  } catch { allPredictions = []; }
}
const movedPredictions = allPredictions.filter((p: any) => p.confidence !== (p.previous ?? p.confidence));

// Load all reports, pick the latest by filename (date sort)
const reportsDir = path.resolve('./src/content/reports');
const files = fs.readdirSync(reportsDir).filter((f: string) => f.endsWith('.md')).sort().reverse();
const latestFile = files[0];
const reportContent = latestFile
  ? fs.readFileSync(path.join(reportsDir, latestFile), 'utf-8')
  : '# No report available yet';

// Parse sections from the markdown
function parseReport(md: string) {
  const sections: { type: string; title: string; content: string }[] = [];
  const lines = md.split('\n');
  let currentSection = { type: 'intro', title: '', content: '' };

  for (const line of lines) {
    if (line.startsWith('### ')) {
      if (currentSection.content.trim()) sections.push({ ...currentSection });
      currentSection = { type: 'h3', title: line.replace('### ', ''), content: '' };
    } else if (line.startsWith('## ')) {
      if (currentSection.content.trim()) sections.push({ ...currentSection });
      currentSection = { type: 'h2', title: line.replace('## ', ''), content: '' };
    } else if (line.startsWith('# ')) {
      // Skip the main title — we render our own
    } else {
      currentSection.content += line + '\n';
    }
  }
  if (currentSection.content.trim()) sections.push({ ...currentSection });
  return sections;
}

function inlineMd(text: string): string {
  return text
    .replace(/\*\*(\d+)\.\s+(".*?")\*\*/g, '<strong class="text-almanac-text text-base">$1. $2</strong>')
    .replace(/\*\*(.+?)\*\*/g, '<strong class="text-almanac-text">$1</strong>')
    .replace(/\*(.+?)\*/g, '<em class="text-almanac-muted/80">$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-almanac-accent hover:underline" target="_blank" rel="noopener">$1</a>')
    .replace(/^---$/gm, '')
    .replace(/(\d{1,3})%/g, '<span class="font-mono text-almanac-accent">$1%</span>');
}

const sections = parseReport(reportContent);
const execSummary = sections.find(s => s.title.includes('Executive Summary'));
const topSignals = sections.find(s => s.title.includes('Top Signals'));
const predictions = sections.find(s => s.title.includes('Predictions'));
const futuresDiff = sections.find(s => s.title.includes('Futures Diff'));
const watching = sections.find(s => s.title.includes('Watching'));

// Parse individual signals from the "Top Signals" section
function parseSignals(content: string) {
  const signals: { title: string; body: string }[] = [];
  const parts = content.split(/\*\*\d+\.\s+/);
  for (const part of parts) {
    if (!part.trim()) continue;
    const titleEnd = part.indexOf('**');
    if (titleEnd > 0) {
      const title = part.slice(0, titleEnd).trim();
      const body = part.slice(titleEnd + 2).trim();
      signals.push({ title, body });
    }
  }
  return signals;
}

const signalItems = topSignals ? parseSignals(topSignals.content) : [];

// Parse prediction updates
function parsePredictions(content: string) {
  const preds: { num: string; claim: string; body: string }[] = [];
  const parts = content.split(/\*\*(\d+)\.\s+/);
  for (let i = 1; i < parts.length; i += 2) {
    const num = parts[i];
    const rest = parts[i + 1] || '';
    const claimEnd = rest.indexOf('**');
    const claim = claimEnd > 0 ? rest.slice(0, claimEnd).replace(/^"/, '').replace(/"$/, '') : '';
    const body = claimEnd > 0 ? rest.slice(claimEnd + 2).trim() : rest;
    preds.push({ num, claim, body });
  }
  return preds;
}

const predItems = predictions ? parsePredictions(predictions.content) : [];
---
<Base title="Today's Forecast — Almanac" description="Daily AI-powered forecast about the future of software engineering.">

  <!-- Hero header -->
  <section class="relative overflow-hidden border-b border-almanac-border">
    <div class="absolute inset-0 bg-gradient-to-b from-almanac-accent/5 to-transparent pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-10 pb-8 relative">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-almanac-green"></span>
          </span>
          <span class="text-sm font-mono text-almanac-muted">March 21, 2026</span>
        </div>
        <span class="text-xs text-almanac-muted bg-almanac-surface px-3 py-1 rounded-full border border-almanac-border" data-en="555 items from 15 sources" data-zh="来自15个数据源的555个项目">
          555 items from 15 sources
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2" data-en="Almanac Daily Forecast" data-zh="Almanac 每日预测">Almanac Daily Forecast</h1>
      <p class="text-almanac-accent text-lg font-medium" data-en="The Future of Software Engineering" data-zh="软件工程的未来">The Future of Software Engineering</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">

    <!-- What Moved Today -->
    {movedPredictions.length > 0 && (
      <FadeIn>
        <div class="mb-8 p-4 rounded-xl border border-almanac-green/20 bg-almanac-green/5">
          <h3 class="text-xs font-semibold text-almanac-green mb-3 uppercase tracking-widest flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <span data-en={`Predictions Moved Today (${movedPredictions.length})`} data-zh={`今日变动预测 (${movedPredictions.length})`}>Predictions Moved Today ({movedPredictions.length})</span>
          </h3>
          <div class="space-y-2">
            {movedPredictions.map((p: any) => {
              const delta = p.confidence - p.previous;
              return (
                <div class="flex items-center gap-3 text-sm">
                  <span class={`font-mono font-bold w-10 text-right ${delta > 0 ? 'text-almanac-green' : 'text-almanac-red'}`}>
                    {delta > 0 ? '+' : ''}{delta}
                  </span>
                  <span class={`font-mono w-12 text-right ${p.confidence >= 60 ? 'text-almanac-green' : p.confidence >= 40 ? 'text-almanac-amber' : 'text-almanac-red'}`}>
                    {p.confidence}%
                  </span>
                  <span class="text-almanac-text truncate flex-1">{p.claim}</span>
                  {p.last_evidence && p.last_evidence !== 'No relevant signal today' && (
                    <span class="text-xs text-almanac-muted hidden md:inline truncate max-w-[200px]">{p.last_evidence}</span>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      </FadeIn>
    )}

    <!-- Diff bar -->
    <FadeIn>
      <div class="mb-10 p-5 rounded-xl border border-almanac-accent/20 bg-almanac-accent/5 backdrop-blur-sm">
        <h3 class="text-xs font-semibold text-almanac-accent mb-4 uppercase tracking-widest flex items-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          <span data-en="What Changed Today" data-zh="今日变化">What Changed Today</span>
        </h3>
        <div class="grid sm:grid-cols-2 gap-3 text-sm">
          <div class="flex items-center gap-2.5">
            <span class="text-almanac-green text-xs">&#9650;</span>
            <span>AI-generated code: <span class="font-mono text-almanac-muted">72% — baseline</span></span>
          </div>
          <div class="flex items-center gap-2.5">
            <span class="text-almanac-green text-xs">&#9650;</span>
            <span>Programmer role: <span class="font-mono text-almanac-muted">68% — baseline</span></span>
          </div>
          <div class="flex items-center gap-2.5">
            <span class="text-almanac-green text-xs">&#9650;</span>
            <span>Security breach: <span class="font-mono text-almanac-red">88% — high confidence</span></span>
          </div>
          <div class="flex items-center gap-2.5">
            <span class="text-almanac-muted text-xs">&mdash;</span>
            <span class="text-almanac-muted">AI fluency premium: 45% — genuinely uncertain</span>
          </div>
        </div>
      </div>
    </FadeIn>

    <!-- Executive Summary -->
    {execSummary && (
      <FadeIn>
        <section class="mb-12">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-1 h-6 rounded-full bg-almanac-accent"></div>
            <h2 class="text-xl font-bold" data-en="Executive Summary" data-zh="执行摘要">{execSummary.title}</h2>
          </div>
          <div class="text-almanac-muted leading-relaxed text-[15px] pl-4 border-l-2 border-almanac-border">
            <Fragment set:html={inlineMd(execSummary.content)} />
          </div>
        </section>
      </FadeIn>
    )}

    <!-- Top Signals -->
    {signalItems.length > 0 && (
      <section class="mb-12">
        <FadeIn>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 rounded-full bg-almanac-amber"></div>
            <h2 class="text-xl font-bold" data-en="Today's Top Signals" data-zh="今日热门信号">Today's Top Signals</h2>
            <span class="text-xs text-almanac-muted bg-almanac-surface px-2 py-0.5 rounded-full border border-almanac-border">{signalItems.length}</span>
          </div>
        </FadeIn>
        <div class="space-y-4">
          {signalItems.map((signal, i) => (
            <FadeIn delay={i * 80}>
              <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface hover:border-almanac-muted/40 transition-all duration-300">
                <div class="flex items-start gap-3 mb-3">
                  <span class="flex-shrink-0 w-7 h-7 rounded-lg bg-almanac-accent/10 text-almanac-accent flex items-center justify-center text-xs font-bold font-mono">{i + 1}</span>
                  <h3 class="font-semibold text-[15px] leading-snug">{signal.title}</h3>
                </div>
                <div class="text-sm text-almanac-muted leading-relaxed pl-10">
                  <Fragment set:html={inlineMd(signal.body)} />
                </div>
              </div>
            </FadeIn>
          ))}
        </div>
      </section>
    )}

    <!-- Predictions Update -->
    {predItems.length > 0 && (
      <section class="mb-12">
        <FadeIn>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 rounded-full bg-almanac-green"></div>
            <h2 class="text-xl font-bold" data-en="Predictions Update" data-zh="预测更新">Predictions Update</h2>
          </div>
        </FadeIn>
        <div class="space-y-3">
          {predItems.map((pred, i) => (
            <FadeIn delay={i * 60}>
              <div class="p-4 rounded-lg border border-almanac-border bg-almanac-surface/50 hover:bg-almanac-surface transition-colors">
                <div class="flex items-start gap-3">
                  <span class="flex-shrink-0 w-6 h-6 rounded-full bg-almanac-border text-almanac-muted flex items-center justify-center text-xs font-mono">{pred.num}</span>
                  <div class="flex-1 min-w-0">
                    {pred.claim && <p class="text-sm font-medium mb-1.5 leading-snug">"{pred.claim}"</p>}
                    <div class="text-xs text-almanac-muted leading-relaxed">
                      <Fragment set:html={inlineMd(pred.body)} />
                    </div>
                  </div>
                </div>
              </div>
            </FadeIn>
          ))}
        </div>
      </section>
    )}

    <!-- Futures Diff -->
    {futuresDiff && (
      <FadeIn>
        <section class="mb-12">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-1 h-6 rounded-full bg-almanac-muted"></div>
            <h2 class="text-xl font-bold" data-en="The Futures Diff" data-zh="未来差异">{futuresDiff.title}</h2>
          </div>
          <div class="text-sm text-almanac-muted leading-relaxed bg-almanac-surface rounded-xl p-5 border border-almanac-border">
            <Fragment set:html={inlineMd(futuresDiff.content)} />
          </div>
        </section>
      </FadeIn>
    )}

    <!-- What We're Watching -->
    {watching && (
      <FadeIn>
        <section class="mb-12">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-1 h-6 rounded-full bg-almanac-accent"></div>
            <h2 class="text-xl font-bold" data-en="What We're Watching" data-zh="我们在关注什么">{watching.title}</h2>
          </div>
          <div class="text-sm text-almanac-muted leading-relaxed">
            <Fragment set:html={inlineMd(watching.content)} />
          </div>
        </section>
      </FadeIn>
    )}

    <!-- Bottom nav -->
    <div class="pt-8 border-t border-almanac-border flex items-center justify-between">
      <span class="text-sm text-almanac-muted font-mono" data-en="Day 2" data-zh="第2天">Day 2</span>
      <a href="/almanac-site/predictions" class="text-sm text-almanac-accent hover:underline flex items-center gap-1">
        <span data-en="View all predictions" data-zh="查看所有预测">View all predictions</span> <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

</Base>
