---
import Base from '../layouts/Base.astro';
import AnimatedGrid from '../components/AnimatedGrid.astro';
import GlowOrb from '../components/GlowOrb.astro';
import Typewriter from '../components/Typewriter.astro';
import SignalTicker from '../components/SignalTicker.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import SourceOrbit from '../components/SourceOrbit.astro';
import GlowCard from '../components/GlowCard.astro';
import FadeIn from '../components/FadeIn.astro';
import ConfidenceGauge from '../components/ConfidenceGauge.astro';
import LivePulse from '../components/LivePulse.astro';
import { loadPredictions } from '../lib/data';
import fs from 'node:fs';
import path from 'node:path';

const allPreds = loadPredictions();

// Dynamic career stats from predictions.json
const findPred = (id: number) => allPreds.find((p: any) => p.id === id);
const devGrowth = findPred(6)?.confidence ?? 60;    // "Total developer headcount HIGHER in 2030"
const systemsSkills = findPred(36)?.confidence ?? 92; // "Systems programming premium HIGHER"
const bottomQuartile = findPred(23)?.confidence ?? 63; // "Bottom quartile salaries LOWER"

// Days since pipeline started running live
const launchDate = new Date('2026-03-20');
const daysLive = Math.max(1, Math.floor((Date.now() - launchDate.getTime()) / 86400000));

// Load latest report for the sample preview
let latestExcerpt = '';
let latestDate = '';
try {
  const reportsDir = path.resolve(process.cwd(), 'src', 'content', 'reports');
  const reports = fs.readdirSync(reportsDir).filter((f: string) => f.endsWith('.md')).sort().reverse();
  if (reports.length > 0) {
    latestDate = reports[0].replace('.md', '');
    const content = fs.readFileSync(path.join(reportsDir, reports[0]), 'utf-8');
    // Extract executive summary
    const match = content.match(/### Executive Summary\s*\n([\s\S]*?)(?=\n###|\n---|\Z)/);
    if (match) latestExcerpt = match[1].trim().slice(0, 300).replace(/\n/g, ' ');
  }
} catch {}

// Find predictions that moved today (for sample preview badges)
const movedPreds = allPreds
  .filter((p: any) => p.confidence !== (p.previous ?? p.confidence))
  .sort((a: any, b: any) => Math.abs(b.confidence - (b.previous ?? b.confidence)) - Math.abs(a.confidence - (a.previous ?? a.confidence)))
  .slice(0, 3);

// Pick 8 representative predictions for the landing page:
// 2 highest confidence, 2 lowest, 2 most recently moved, 2 contrarian
const sorted = [...allPreds].sort((a, b) => b.confidence - a.confidence);
const moved = [...allPreds].filter(p => p.confidence !== (p.previous ?? p.confidence));
const contrarian = allPreds.filter(p => p.type === 'contrarian');

const picked = new Set<number>();
const predictions: any[] = [];
function addPred(p: any) {
  if (picked.has(p.id) || predictions.length >= 8) return;
  picked.add(p.id);
  const delta = p.confidence - (p.previous ?? p.confidence);
  predictions.push({
    claim: p.claim,
    claim_zh: p.claim_zh || p.claim,
    confidence: p.confidence,
    delta: delta === 0 ? "0" : (delta > 0 ? `+${delta}` : `${delta}`),
    category: p.category,
    category_zh: p.category_zh || p.category,
    history: [p.confidence],
    type: p.type || 'consensus',
  });
}
// 2 highest
sorted.slice(0, 2).forEach(addPred);
// 2 lowest
sorted.slice(-2).reverse().forEach(addPred);
// 2 most moved (or contrarian if none moved)
if (moved.length > 0) {
  moved.sort((a, b) => Math.abs(b.confidence - (b.previous ?? b.confidence)) - Math.abs(a.confidence - (a.previous ?? a.confidence)));
  moved.slice(0, 2).forEach(addPred);
}
// Fill remaining with contrarian picks spread across categories
const usedCats = new Set(predictions.map(p => p.category));
for (const p of contrarian) {
  if (predictions.length >= 8) break;
  if (!usedCats.has(p.category)) {
    addPred(p);
    usedCats.add(p.category);
  }
}
// If still < 8, fill from middle of the distribution
const midStart = Math.floor(sorted.length / 2) - 2;
for (let i = midStart; i < sorted.length && predictions.length < 8; i++) {
  addPred(sorted[i]);
}

const movedToday = moved.length;

// Top moved prediction for dynamic "Biggest Move" section
const topMoved = movedPreds.length > 0 ? movedPreds[0] : null;
const topMovedDelta = topMoved ? topMoved.confidence - (topMoved.previous ?? topMoved.confidence) : 0;
const topMovedDeltaStr = topMovedDelta > 0 ? `+${topMovedDelta}` : `${topMovedDelta}`;

const totalPreds = allPreds.length;
const avgConf = totalPreds > 0 ? Math.round(allPreds.reduce((a: number, p: any) => a + p.confidence, 0) / totalPreds) : 50;
---
<Base title="Almanac — The modern almanac for an uncertain future">

  <!-- HERO: Split layout — left text, right gauge -->
  <section class="relative overflow-hidden">
    <AnimatedGrid />
    <GlowOrb />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="grid lg:grid-cols-5 gap-8 items-center min-h-[60vh] sm:min-h-[85vh] py-10 sm:py-16">

        <!-- Left: Text -->
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-almanac-border text-xs text-almanac-muted mb-6 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
            </span>
            <span data-en={`Live — Day ${daysLive} of daily tracking`} data-zh={`实时运行 — 第${daysLive}天持续追踪`}>Live — Day {daysLive} of daily tracking</span>
          </div>
          <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
            <span data-en="The modern" data-zh="面向未来的">The modern</span><br/>
            <span data-en="almanac for" data-zh="现代年鉴：">almanac for</span><br/>
            <span class="text-almanac-accent" data-en="software engineering" data-zh="软件工程">software engineering</span>
          </h1>
          <p class="mt-3 text-base text-almanac-muted/60 flex items-center gap-2">
            <span class="w-4 h-px bg-almanac-accent/50"></span>
            <Typewriter texts={["an uncertain future", "the next decade", "what comes next", "career decisions"]} textsZh={["不确定的未来", "下一个十年", "即将到来的变化", "职业抉择"]} speed={70} />
          </p>
          <p class="mt-4 sm:mt-6 text-base sm:text-lg text-almanac-muted max-w-xl leading-relaxed">
            <span data-en="Will AI replace your job or make it more valuable?" data-zh="AI会取代你的工作还是让它更有价值？">Will AI replace your job or make it more valuable?</span>
            <span class="hidden sm:inline" data-en=" Will Rust salaries rise? Will junior hiring recover?" data-zh=" Rust薪资会上涨吗？初级岗位招聘会恢复吗？"> Will Rust salaries rise? Will junior hiring recover?</span>
            <span data-en=" 50 predictions, updated daily from 17+ sources — career decisions based on evidence, not anxiety." data-zh=" 50项预测，每天从17+个数据源更新——让职业决策基于证据，而非焦虑。"> 50 predictions, updated daily from 17+ sources — career decisions based on evidence, not anxiety.</span>
          </p>

          <p class="mt-3 text-xs text-almanac-muted/70 hidden sm:block" data-en="Unlike prediction markets, we track software-engineering-specific forecasts no one else covers — from AI debugging job emergence to Rust salary premiums — with daily updates tied to specific news events." data-zh="与预测市场不同，我们追踪无人覆盖的软件工程专属预测——从AI调试岗位出现到Rust薪资溢价——每日更新均关联具体新闻事件。">
            Unlike prediction markets, we track software-engineering-specific forecasts no one else covers — from AI debugging job emergence to Rust salary premiums — with daily updates tied to specific news events.
          </p>

          <!-- Hero email signup -->
          <form id="hero-form" class="mt-8 flex flex-col sm:flex-row gap-2 max-w-md" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="56e74bc1-d00f-4ff8-ad35-a00eb74f716d" />
            <input type="hidden" name="subject" value="New Almanac subscriber (hero)" />
            <input type="hidden" name="from_name" value="Almanac Signup" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <input type="email" name="email" required placeholder="you@company.com"
              data-en-placeholder="you@company.com" data-zh-placeholder="你的邮箱地址"
              class="flex-1 px-4 py-3 rounded-lg bg-almanac-surface border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent focus:ring-1 focus:ring-almanac-accent/30 transition-all text-sm" />
            <button type="submit"
              class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300 text-sm whitespace-nowrap cursor-pointer flex items-center gap-2">
              <span class="btn-text" data-en="Get Tomorrow's Forecast" data-zh="获取明天的预测">Get Tomorrow's Forecast</span>
              <svg class="btn-spinner hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </form>
          <p class="mt-2 text-[11px] text-almanac-muted" data-en="Free daily email. No spam. Unsubscribe anytime." data-zh="免费每日邮件，无垃圾信息，随时退订。">Free daily email. No spam. Unsubscribe anytime.</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/almanac-site/forecast" class="group text-sm text-almanac-accent hover:underline flex items-center gap-1" data-en="Read today's forecast" data-zh="阅读今日预测">
              Read today's forecast <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
            <span class="text-almanac-border">|</span>
            <a href="/almanac-site/dashboard" class="text-sm text-almanac-muted hover:text-almanac-text transition" data-en="Dashboard" data-zh="数据面板">
              Dashboard
            </a>
            <span class="text-almanac-border">|</span>
            <a href="https://github.com/YingxuH/almanac" class="text-sm text-almanac-muted hover:text-almanac-text transition">
              GitHub
            </a>
          </div>
        </div>

        <!-- Right: Gauge + context + mini stats -->
        <div class="lg:col-span-2 flex flex-col items-center gap-4">
          <ConfidenceGauge value={avgConf} size={240} />
          <p class="text-xs text-almanac-muted text-center max-w-[240px] leading-relaxed" data-en={`${avgConf}% means roughly ${avgConf}-in-100 chance. Near 50% = genuine uncertainty — we quantify what we don't know, not just what we do.`} data-zh={`${avgConf}%意味着约${avgConf}/100的概率。接近50% = 真正的不确定性——我们不仅量化已知，也量化未知。`}>
            {avgConf}% means roughly {avgConf}-in-100 chance. Near 50% = genuine uncertainty — we quantify what we don't know, not just what we do.
          </p>
          <div class="grid grid-cols-3 gap-4 w-full max-w-xs">
            <div class="text-center">
              <div class="text-xl font-bold font-mono text-almanac-accent">{totalPreds}</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider" data-en="Predictions" data-zh="预测数">Predictions</div>
            </div>
            <a href="/almanac-site/forecast" class="text-center group">
              <div class="text-xl font-bold font-mono text-almanac-green group-hover:text-almanac-accent transition-colors">{movedToday || '—'}</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider group-hover:text-almanac-text transition-colors" data-en="Moved Today" data-zh="今日变动">Moved Today</div>
            </a>
            <div class="text-center">
              <div class="text-xl font-bold font-mono">17+</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider" data-en="Daily Sources" data-zh="每日数据源">Daily Sources</div>
            </div>
          </div>
          {/* Contrarian teaser below stats */}
          {contrarian.length > 0 && (() => {
            const pick = contrarian.find(p => p.confidence !== (p.previous ?? p.confidence)) || contrarian[0];
            return (
              <a href="/almanac-site/predictions" class="mt-3 block w-full max-w-xs p-2.5 rounded-lg border border-almanac-amber/20 bg-almanac-amber/5 hover:border-almanac-amber/40 transition-colors text-left">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-[10px] font-bold text-almanac-amber uppercase tracking-wider" data-en="Contrarian" data-zh="逆向预测">Contrarian</span>
                  <span class="text-sm font-bold font-mono text-almanac-amber">{pick.confidence}%</span>
                </div>
                <p class="text-xs text-almanac-muted leading-snug line-clamp-2" data-en={pick.claim} data-zh={pick.claim_zh || pick.claim}>{pick.claim}</p>
              </a>
            );
          })()}
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar — moved up, right after hero. Plain English, honest caveats inline -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4">
    <div class="flex flex-wrap items-center justify-center gap-6 text-xs text-almanac-muted">
      <a href="/almanac-site/validation" class="flex items-center gap-1.5 hover:text-almanac-accent transition-colors">
        <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span data-en="Tested against 20 past events: got 16 right (pre-launch test, not live data yet)" data-zh="对20个历史事件测试：答对16个（上线前测试，非实时数据）">Tested against 20 past events: got 16 right (pre-launch test, not live data yet)</span>
      </a>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-almanac-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        <span data-en="5 AI personas (not humans) with different worldviews challenge each prediction" data-zh="5个AI角色（非真人），以不同世界观挑战每项预测">5 AI personas (not humans) with different worldviews challenge each prediction</span>
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-almanac-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        <span data-en="We publish our misses — see all 4 we got wrong" data-zh="我们公开失误——查看我们的4次错误">We publish our misses — see all 4 we got wrong</span>
      </span>
    </div>
  </div>

  <!-- What it means for your career — moved up as the emotional hook right after trust -->
  <div class="bg-almanac-surface/50 border-y border-almanac-border">
  <FadeIn>
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
      <h2 class="text-2xl font-bold mb-2 text-center" data-en="What the data says about your career" data-zh="数据对你的职业意味着什么">What the data says about your career</h2>
      <p class="text-sm text-almanac-muted text-center mb-6" data-en="The three questions every software engineer is asking right now — with probabilities, not opinions." data-zh="每位软件工程师现在都在问的三个问题——用概率而非观点来回答。">The three questions every software engineer is asking right now — with probabilities, not opinions.</p>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface">
          <div class="text-2xl font-bold font-mono text-almanac-green mb-2">{devGrowth}%</div>
          <p class="text-sm font-medium mb-1" data-en="More developers, not fewer" data-zh="更多开发者，而不是更少">More developers, not fewer</p>
          <p class="text-xs text-almanac-muted" data-en="Our models suggest total developer headcount will likely GROW by 2030. Every previous automation wave expanded employment in the affected sector." data-zh="我们的模型表明，到2030年开发者总数可能会增长。每一次自动化浪潮都扩大了相关行业的就业。">Our models suggest total developer headcount will likely GROW by 2030. Every previous automation wave expanded employment in the affected sector.</p>
        </div>
        <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface">
          <div class="text-2xl font-bold font-mono text-almanac-amber mb-2">{systemsSkills}%</div>
          <p class="text-sm font-medium mb-1" data-en="Systems skills pay more" data-zh="系统技能更值钱">Systems skills pay more</p>
          <p class="text-xs text-almanac-muted" data-en="Rust, C++, and kernel development will command higher premiums as AI handles high-level code generation. Deep technical skills become more valuable, not less." data-zh="随着AI处理高级代码生成，Rust、C++和内核开发将获得更高溢价。深度技术技能变得更有价值。">Rust, C++, and kernel development will command higher premiums as AI handles high-level code generation. Deep technical skills become more valuable, not less.</p>
        </div>
        <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface">
          <div class="text-2xl font-bold font-mono text-almanac-red mb-2">{bottomQuartile}%</div>
          <p class="text-sm font-medium mb-1" data-en="The floor drops, the ceiling rises" data-zh="底部下降，顶部上升">The floor drops, the ceiling rises</p>
          <p class="text-xs text-almanac-muted" data-en="Bottom-quartile developer salaries likely decline as AI commoditizes routine work — but Staff+ engineer pay is expected to rise 20%+. The gap widens. Upskilling matters more than ever." data-zh="AI使常规工作商品化，底部薪资可能下降——但Staff+工程师薪酬预计上涨20%以上。差距在扩大。提升技能比以往更重要。">Bottom-quartile developer salaries likely decline as AI commoditizes routine work — but Staff+ engineer pay is expected to rise 20%+. The gap widens. Upskilling matters more than ever.</p>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- Mid-page CTA — interest peaks after career cards -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 text-center">
    <form class="inline-flex flex-col sm:flex-row gap-2 items-center" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="56e74bc1-d00f-4ff8-ad35-a00eb74f716d" />
      <input type="hidden" name="subject" value="New Almanac subscriber (mid-page)" />
      <input type="hidden" name="from_name" value="Almanac Signup" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
      <input type="email" name="email" required placeholder="you@company.com"
        class="px-4 py-2.5 rounded-lg bg-almanac-surface border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent text-sm w-64" />
      <button type="submit"
        class="px-5 py-2.5 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-lg transition-all text-sm whitespace-nowrap cursor-pointer">
        <span data-en="Get these predictions daily" data-zh="每日获取这些预测">Get these predictions daily</span>
      </button>
    </form>
    <p class="mt-2 text-[10px] text-almanac-muted" data-en="Free. No spam. Unsubscribe anytime." data-zh="免费，无垃圾邮件，随时退订。">Free. No spam. Unsubscribe anytime.</p>
  </div>

  </div><!-- end career bg -->

  <!-- Sample forecast preview — dynamically generated from latest report + predictions -->
  <FadeIn>
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="rounded-xl border border-almanac-border bg-almanac-surface overflow-hidden">
        <div class="px-6 py-3 border-b border-almanac-border flex items-center justify-between">
          <span class="text-xs text-almanac-muted uppercase tracking-widest" data-en="Sample: What you get daily" data-zh="示例：每日推送内容">Sample: What you get daily</span>
          <a href="/almanac-site/forecast" class="text-xs text-almanac-accent hover:underline" data-en="Read full report" data-zh="阅读完整报告">Read full report &rarr;</a>
        </div>
        <div class="p-5 sm:p-6">
          <div class="flex items-center gap-3 mb-3">
            {latestDate && <span class="text-xs font-mono text-almanac-muted bg-almanac-border px-2 py-0.5 rounded">{latestDate}</span>}
            <span class="text-xs text-almanac-green font-mono">{movedPreds.length > 0 ? `${allPreds.filter((p: any) => p.confidence !== (p.previous ?? p.confidence)).length} predictions moved` : 'Daily forecast'}</span>
          </div>
          {latestExcerpt ? (
            <p class="text-sm text-almanac-muted leading-relaxed mb-4">{latestExcerpt}...</p>
          ) : (
            <p class="text-sm text-almanac-muted leading-relaxed mb-4">Each morning, Almanac synthesizes signals from 17+ sources into a concise forecast with specific, source-linked prediction updates.</p>
          )}
          <div class="flex flex-wrap gap-2">
            {movedPreds.length > 0 ? movedPreds.map((p: any) => {
              const delta = p.confidence - (p.previous ?? p.confidence);
              const color = delta > 0 ? 'bg-almanac-green/10 text-almanac-green border-almanac-green/20' : 'bg-almanac-red/10 text-almanac-red border-almanac-red/20';
              return (
                <span class={`text-[10px] px-2 py-1 rounded border ${color}`}>
                  P{p.id}: {p.claim.slice(0, 40)}... {p.confidence}% ({delta > 0 ? '+' : ''}{delta})
                </span>
              );
            }) : (
              <span class="text-[10px] px-2 py-1 rounded bg-almanac-border text-almanac-muted" data-en="Subscribe to see daily prediction movements" data-zh="订阅查看每日预测变动">Subscribe to see daily prediction movements</span>
            )}
          </div>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- Signal Ticker removed — contained hardcoded data -->

  <!-- Today's biggest move — DYNAMIC from pipeline data, only shown when predictions moved -->
  {topMoved && (
    <FadeIn>
      <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
        <div class="relative">
          <div class="absolute -inset-2 bg-almanac-accent/5 rounded-2xl blur-2xl"></div>
          <div class="relative rounded-xl border border-almanac-accent/20 bg-almanac-surface overflow-hidden">
            <div class="px-6 py-3 border-b border-almanac-border flex items-center justify-between bg-almanac-accent/5">
              <div class="flex items-center gap-2">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
                </span>
