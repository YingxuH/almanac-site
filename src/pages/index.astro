---
import Base from '../layouts/Base.astro';
import AnimatedGrid from '../components/AnimatedGrid.astro';
import GlowOrb from '../components/GlowOrb.astro';
import Typewriter from '../components/Typewriter.astro';
import SignalTicker from '../components/SignalTicker.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import SourceOrbit from '../components/SourceOrbit.astro';
import GlowCard from '../components/GlowCard.astro';
import FadeIn from '../components/FadeIn.astro';

const predictions = [
  { claim: ">50% of Fortune 500 production code AI-generated by 2028", confidence: 74, delta: "+6", category: "AI Coding" },
  { claim: "'Computer Programmer' job title ceases at large companies by 2031", confidence: 77, delta: "+3", category: "Labor" },
  { claim: "Senior engineer shortage dominates talent crisis by 2030-2032", confidence: 80, delta: "+3", category: "Labor" },
  { claim: "Multi-agent AI handles >30% of all QA work by 2028", confidence: 76, delta: "0", category: "Automation" },
  { claim: "Major AI-generated code security breach before 2029", confidence: 72, delta: "0", category: "Security" },
  { claim: "Engineers spend more time reviewing AI code than writing by 2032", confidence: 72, delta: "0", category: "Workflow" },
  { claim: "Most valuable tech skill by 2036 will be 'AI system judgment'", confidence: 78, delta: "0", category: "Skills" },
  { claim: "AI-fluent engineers earn $40K+ more than peers by 2029", confidence: 71, delta: "0", category: "Compensation" },
];
---
<Base title="Almanac — The modern almanac for an uncertain future">

  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center">
    <AnimatedGrid />
    <GlowOrb />
    <div class="max-w-4xl mx-auto px-6 pt-12 pb-16 text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-almanac-border text-xs text-almanac-muted mb-8 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
        </span>
        Updated March 21, 2026
      </div>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-[1.1]">
        The modern almanac for<br/>
        <span class="text-almanac-accent">
          <Typewriter texts={["an uncertain future", "software engineering", "the next decade", "what comes next"]} speed={70} />
        </span>
      </h1>
      <p class="mt-8 text-lg md:text-xl text-almanac-muted max-w-2xl mx-auto leading-relaxed">
        Every morning, AI reads thousands of signals from research papers, news, job markets,
        and developer communities. You read what matters — confidence-scored forecasts, updated every 24 hours.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/almanac-site/forecast" class="group px-8 py-3.5 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300">
          Read Today's Forecast
          <span class="inline-block transition-transform group-hover:translate-x-1 ml-1">&rarr;</span>
        </a>
        <a href="https://github.com/YingxuH/almanac" class="px-8 py-3.5 border border-almanac-border rounded-lg hover:border-almanac-muted hover:bg-almanac-surface/50 transition-all duration-300">
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Signal Ticker -->
  <SignalTicker />

  <!-- Stats counters -->
  <FadeIn>
    <section class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <AnimatedCounter value={265} label="Signals ingested today" />
        <AnimatedCounter value={8} label="Active predictions" />
        <AnimatedCounter value={6} label="Data sources live" />
        <AnimatedCounter value={1} label="Days tracking" suffix="+" />
      </div>
    </section>
  </FadeIn>

  <!-- How it works + Source orbit -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Left: Steps -->
      <div>
        <FadeIn>
          <h2 class="text-3xl font-bold mb-10">How it works</h2>
        </FadeIn>
        <div class="space-y-8">
          <FadeIn delay={100}>
            <GlowCard>
              <div class="p-6">
                <div class="flex items-center gap-4 mb-3">
                  <span class="text-2xl font-bold text-almanac-accent font-mono">01</span>
                  <h3 class="font-semibold text-lg">Ingest</h3>
                </div>
                <p class="text-almanac-muted text-sm leading-relaxed">AI agents scrape 10+ sources overnight — arXiv papers, Hacker News, job boards, GitHub trends, RSS feeds, prediction markets.</p>
              </div>
            </GlowCard>
          </FadeIn>
          <FadeIn delay={200}>
            <GlowCard>
              <div class="p-6">
                <div class="flex items-center gap-4 mb-3">
                  <span class="text-2xl font-bold text-almanac-accent font-mono">02</span>
                  <h3 class="font-semibold text-lg">Analyze</h3>
                </div>
                <p class="text-almanac-muted text-sm leading-relaxed">Signals are filtered and synthesized into a coherent narrative. Every claim is source-linked. Every prediction has a confidence score.</p>
              </div>
            </GlowCard>
          </FadeIn>
          <FadeIn delay={300}>
            <GlowCard>
              <div class="p-6">
                <div class="flex items-center gap-4 mb-3">
                  <span class="text-2xl font-bold text-almanac-accent font-mono">03</span>
                  <h3 class="font-semibold text-lg">Forecast</h3>
                </div>
                <p class="text-almanac-muted text-sm leading-relaxed">Predictions update via Bayesian reasoning. The daily Futures Diff shows exactly what changed, by how much, and why.</p>
              </div>
            </GlowCard>
          </FadeIn>
        </div>
      </div>
      <!-- Right: Source orbit -->
      <FadeIn direction="right">
        <div class="flex items-center justify-center">
          <SourceOrbit />
        </div>
      </FadeIn>
    </div>
  </section>

  <!-- Today's Signal Preview -->
  <FadeIn>
    <section class="max-w-5xl mx-auto px-6 py-8">
      <GlowCard>
        <div class="px-6 py-4 border-b border-almanac-border flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
            </span>
            <span class="text-sm text-almanac-muted">FROM TODAY'S FORECAST — March 21, 2026</span>
          </div>
          <a href="/almanac-site/forecast" class="text-sm text-almanac-accent hover:underline">Read full report &rarr;</a>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-semibold mb-3">The "Productivity Panic" and Developer Burnout</h3>
          <p class="text-almanac-muted leading-relaxed text-sm">
            Bloomberg reported on the "Great Productivity Panic of 2026." Engineers report spending >80% of their
            day iterating with AI, generating output at a speed they cannot validate. The bottleneck in software
            creation has officially moved from code generation to human validation.
          </p>
          <div class="mt-4 flex items-center gap-4 text-xs text-almanac-muted">
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-almanac-amber"></span>
              Impact: High
            </span>
            <span>Sources: Bloomberg, Hacker News</span>
            <span>Horizon: 3-10 years</span>
          </div>
        </div>
      </GlowCard>
    </section>
  </FadeIn>

  <!-- Predictions -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <FadeIn>
      <h2 class="text-3xl font-bold mb-2">Active Predictions</h2>
      <p class="text-almanac-muted mb-10">8 specific, falsifiable forecasts — tracked daily with confidence scores.</p>
    </FadeIn>

    <div class="space-y-3">
      {predictions.map((p, i) => (
        <FadeIn delay={i * 75}>
          <div class="flex items-center gap-4 p-4 rounded-lg border border-almanac-border bg-almanac-surface hover:border-almanac-accent/30 hover:shadow-[0_0_20px_rgba(34,211,238,0.05)] transition-all duration-300 group">
            <div class="flex-shrink-0 w-16 text-center">
              <div class={`text-2xl font-bold font-mono transition-transform duration-300 group-hover:scale-110 ${p.confidence >= 75 ? 'text-almanac-green' : p.confidence >= 60 ? 'text-almanac-amber' : 'text-almanac-red'}`}>
                {p.confidence}%
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium leading-snug">{p.claim}</p>
              <div class="flex items-center gap-3 mt-1.5 text-xs text-almanac-muted">
                <span class="px-2 py-0.5 rounded bg-almanac-border text-[10px] uppercase tracking-wider">{p.category}</span>
                <span class={p.delta.startsWith('+') ? 'text-almanac-green font-mono' : p.delta === '0' ? 'text-almanac-muted' : 'text-almanac-red font-mono'}>
                  {p.delta === '0' ? 'unchanged' : p.delta + ' today'}
                </span>
              </div>
            </div>
            <div class="flex-shrink-0 hidden sm:block">
              <div class="w-28 h-2.5 rounded-full bg-almanac-border overflow-hidden">
                <div
                  class={`h-full rounded-full transition-all duration-1000 ${p.confidence >= 75 ? 'bg-almanac-green' : p.confidence >= 60 ? 'bg-almanac-amber' : 'bg-almanac-red'}`}
                  style={`width: ${p.confidence}%`}
                />
              </div>
            </div>
          </div>
        </FadeIn>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <FadeIn>
    <section class="max-w-3xl mx-auto px-6 py-20 text-center">
      <div class="relative">
        <div class="absolute -inset-4 bg-almanac-accent/5 rounded-2xl blur-xl"></div>
        <div class="relative p-10 rounded-xl border border-almanac-border bg-almanac-surface">
          <h2 class="text-3xl font-bold mb-4">The future updates daily.</h2>
          <p class="text-almanac-muted mb-8 text-lg">Open source. Confidence-scored. Source-linked.<br/>Built to be proven wrong.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/almanac-site/forecast" class="group px-8 py-3.5 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300">
              Read Today's Forecast
              <span class="inline-block transition-transform group-hover:translate-x-1 ml-1">&rarr;</span>
            </a>
            <a href="https://github.com/YingxuH/almanac" class="px-8 py-3.5 border border-almanac-border rounded-lg hover:border-almanac-muted hover:bg-almanac-surface/50 transition-all duration-300">
              Star on GitHub
            </a>
          </div>
        </div>
      </div>
    </section>
  </FadeIn>

</Base>
