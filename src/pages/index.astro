---
import Base from '../layouts/Base.astro';

const predictions = [
  { claim: ">50% of Fortune 500 production code AI-generated by 2028", confidence: 74, delta: "+6", category: "AI Coding" },
  { claim: "'Computer Programmer' job title ceases at large companies by 2031", confidence: 77, delta: "+3", category: "Labor" },
  { claim: "Senior engineer shortage dominates talent crisis by 2030-2032", confidence: 80, delta: "+3", category: "Labor" },
  { claim: "Multi-agent AI handles >30% of all QA work by 2028", confidence: 76, delta: "0", category: "Automation" },
  { claim: "Major AI-generated code security breach before 2029", confidence: 72, delta: "0", category: "Security" },
  { claim: "Engineers spend more time reviewing AI code than writing by 2032", confidence: 72, delta: "0", category: "Workflow" },
  { claim: "Most valuable tech skill by 2036 will be 'AI system judgment'", confidence: 78, delta: "0", category: "Skills" },
  { claim: "AI-fluent engineers earn $40K+ more than peers by 2029", confidence: 71, delta: "0", category: "Compensation" },
];
---
<Base title="Almanac — The modern almanac for an uncertain future">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-almanac-accent/5 to-transparent pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-6 pt-24 pb-16 text-center relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-almanac-border text-xs text-almanac-muted mb-6">
        <span class="w-2 h-2 rounded-full bg-almanac-green animate-pulse"></span>
        Updated March 21, 2026
      </div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight leading-tight">
        The modern almanac for<br/>
        <span class="text-almanac-accent">an uncertain future</span>
      </h1>
      <p class="mt-6 text-lg text-almanac-muted max-w-2xl mx-auto leading-relaxed">
        Every morning, AI reads thousands of signals from research papers, news, job markets,
        and developer communities. You read what matters — confidence-scored forecasts about the
        future of software engineering, updated every 24 hours.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/forecast" class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:bg-almanac-accent/90 transition">
          Read Today's Forecast
        </a>
        <a href="https://github.com/YingxuH/almanac" class="px-6 py-3 border border-almanac-border rounded-lg hover:border-almanac-muted transition">
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="p-6 rounded-xl border border-almanac-border bg-almanac-surface">
        <div class="text-3xl font-bold text-almanac-accent mb-3">01</div>
        <h3 class="font-semibold text-lg mb-2">Ingest</h3>
        <p class="text-almanac-muted text-sm leading-relaxed">AI agents scrape 10+ sources overnight — arXiv papers, Hacker News, job boards, GitHub trends, RSS feeds, prediction markets.</p>
      </div>
      <div class="p-6 rounded-xl border border-almanac-border bg-almanac-surface">
        <div class="text-3xl font-bold text-almanac-accent mb-3">02</div>
        <h3 class="font-semibold text-lg mb-2">Analyze</h3>
        <p class="text-almanac-muted text-sm leading-relaxed">Signals are filtered, analyzed, and synthesized into a coherent narrative. Every claim is source-linked. Every prediction has a confidence score.</p>
      </div>
      <div class="p-6 rounded-xl border border-almanac-border bg-almanac-surface">
        <div class="text-3xl font-bold text-almanac-accent mb-3">03</div>
        <h3 class="font-semibold text-lg mb-2">Forecast</h3>
        <p class="text-almanac-muted text-sm leading-relaxed">Predictions update via Bayesian reasoning. The daily Futures Diff shows exactly what changed, by how much, and why. We publish our accuracy.</p>
      </div>
    </div>
  </section>

  <!-- Today's Signal Preview -->
  <section class="max-w-5xl mx-auto px-6 py-8">
    <div class="rounded-xl border border-almanac-border bg-almanac-surface overflow-hidden">
      <div class="px-6 py-4 border-b border-almanac-border flex items-center justify-between">
        <span class="text-sm text-almanac-muted">FROM TODAY'S FORECAST — March 21, 2026</span>
        <a href="/forecast" class="text-sm text-almanac-accent hover:underline">Read full report</a>
      </div>
      <div class="p-6">
        <h3 class="text-xl font-semibold mb-3">The "Productivity Panic" and Developer Burnout</h3>
        <p class="text-almanac-muted leading-relaxed text-sm">
          Bloomberg reported on the "Great Productivity Panic of 2026." Engineers report spending >80% of their
          day iterating with AI, generating output at a speed they cannot validate. The bottleneck in software
          creation has officially moved from code generation to human validation.
        </p>
        <div class="mt-4 flex items-center gap-4 text-xs text-almanac-muted">
          <span class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-almanac-amber"></span>
            Impact: High
          </span>
          <span>Sources: Bloomberg, Hacker News</span>
          <span>Horizon: 3-10 years</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Predictions Table -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold mb-2">Active Predictions</h2>
    <p class="text-almanac-muted mb-8">8 specific, falsifiable forecasts — tracked daily with confidence scores.</p>

    <div class="space-y-3">
      {predictions.map((p) => (
        <div class="flex items-center gap-4 p-4 rounded-lg border border-almanac-border bg-almanac-surface hover:border-almanac-muted/50 transition group">
          <div class="flex-shrink-0 w-16 text-center">
            <div class={`text-2xl font-bold font-mono ${p.confidence >= 75 ? 'text-almanac-green' : p.confidence >= 60 ? 'text-almanac-amber' : 'text-almanac-red'}`}>
              {p.confidence}%
            </div>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium leading-snug">{p.claim}</p>
            <div class="flex items-center gap-3 mt-1 text-xs text-almanac-muted">
              <span class="px-2 py-0.5 rounded bg-almanac-border">{p.category}</span>
              <span class={p.delta.startsWith('+') ? 'text-almanac-green' : p.delta === '0' ? 'text-almanac-muted' : 'text-almanac-red'}>
                {p.delta === '0' ? 'unchanged' : p.delta + ' today'}
              </span>
            </div>
          </div>
          <div class="flex-shrink-0">
            <div class="w-24 h-2 rounded-full bg-almanac-border overflow-hidden">
              <div class={`h-full rounded-full ${p.confidence >= 75 ? 'bg-almanac-green' : p.confidence >= 60 ? 'bg-almanac-amber' : 'bg-almanac-red'}`} style={`width: ${p.confidence}%`}></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-6 py-16 text-center">
    <div class="p-8 rounded-xl border border-almanac-border bg-almanac-surface">
      <h2 class="text-2xl font-bold mb-3">The future updates daily.</h2>
      <p class="text-almanac-muted mb-6">Open source. Confidence-scored. Source-linked. Built to be proven wrong.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/forecast" class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:bg-almanac-accent/90 transition">
          Read Today's Forecast
        </a>
        <a href="https://github.com/YingxuH/almanac" class="px-6 py-3 border border-almanac-border rounded-lg hover:border-almanac-muted transition">
          Star on GitHub
        </a>
      </div>
    </div>
  </section>

</Base>
