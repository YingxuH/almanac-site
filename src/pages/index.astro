  <!-- Embed current predictions for client-side return-visitor comparison -->
  <script id="predictions-data" type="application/json" set:html={JSON.stringify(allPreds.map((p: any) => ({id: p.id, confidence: p.confidence, claim: p.claim})))}></script>

  <!-- Return-visitor "Since your last visit" banner -->
  <script is:inline>
  (function() {
    var STORAGE_KEY_TS = 'almanac-last-visit';
    var STORAGE_KEY_SNAP = 'almanac-snapshot';
    var SIX_HOURS_MS = 6 * 60 * 60 * 1000;

    function getCurrentSnapshot() {
      try {
        var el = document.getElementById('predictions-data');
        if (!el) return null;
        return JSON.parse(el.textContent || el.innerHTML);
      } catch (e) { return null; }
    }

    function saveVisit(snapshot) {
      try {
        localStorage.setItem(STORAGE_KEY_TS, Date.now().toString());
        if (snapshot) localStorage.setItem(STORAGE_KEY_SNAP, JSON.stringify(snapshot));
      } catch (e) {}
    }

    function renderBanner(movedCount, biggestMover, totalDelta) {
      var existing = document.getElementById('almanac-since-visit-banner');
      if (existing) return; // already rendered

      var dirStr = biggestMover.delta > 0 ? '+' + biggestMover.delta : '' + biggestMover.delta;
      var dirColor = biggestMover.delta > 0 ? '#22d3ee' : '#f87171';

      var banner = document.createElement('div');
      banner.id = 'almanac-since-visit-banner';
      banner.style.cssText = [
        'position:relative',
        'max-width:1280px',
        'margin:0 auto 0',
        'padding:0 1rem',
        'z-index:40',
      ].join(';');

      banner.innerHTML = [
        '<div style="',
          'border:1px solid rgba(34,211,238,0.3);',
          'border-radius:12px;',
          'background:rgba(34,211,238,0.05);',
          'padding:12px 16px;',
          'display:flex;',
          'align-items:center;',
          'justify-content:space-between;',
          'gap:12px;',
          'flex-wrap:wrap;',
        '">',
          '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;min-width:0;">',
            '<span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#22d3ee;white-space:nowrap;">Since your last visit</span>',
            '<span style="font-size:12px;color:#94a3b8;">',
              '<strong style="color:#e2e8f0;">' + movedCount + '</strong> prediction' + (movedCount === 1 ? '' : 's') + ' moved',
              ' &mdash; biggest: <strong style="color:' + dirColor + ';">' + dirStr + '%</strong>',
              ' on <em style="color:#e2e8f0;">' + biggestMover.claim.slice(0, 55) + (biggestMover.claim.length > 55 ? '&hellip;' : '') + '</em>',
              ' (now ' + biggestMover.confidence + '%)',
            '</span>',
          '</div>',
          '<button id="almanac-banner-dismiss" style="',
            'flex-shrink:0;',
            'background:none;',
            'border:none;',
            'cursor:pointer;',
            'color:#64748b;',
            'font-size:16px;',
            'line-height:1;',
            'padding:2px 4px;',
          '" aria-label="Dismiss">&times;</button>',
        '</div>',
      ].join('');

      // Insert after the trust bar (second section-level div after hero)
      var heroSection = document.querySelector('section.relative.overflow-hidden');
      if (heroSection && heroSection.nextElementSibling) {
        heroSection.parentNode.insertBefore(banner, heroSection.nextElementSibling);
      } else {
        document.body.insertBefore(banner, document.body.firstChild);
      }

      document.getElementById('almanac-banner-dismiss').addEventListener('click', function() {
        banner.remove();
      });
    }

    function init() {
      var currentSnapshot = getCurrentSnapshot();
      var lastVisitTs = null;
      var lastSnapshot = null;
      try {
        lastVisitTs = parseInt(localStorage.getItem(STORAGE_KEY_TS) || '0', 10);
        var raw = localStorage.getItem(STORAGE_KEY_SNAP);
        if (raw) lastSnapshot = JSON.parse(raw);
      } catch (e) {}

      var now = Date.now();

      if (lastVisitTs && (now - lastVisitTs) > SIX_HOURS_MS && lastSnapshot && currentSnapshot) {
        // Build lookup for last snapshot
        var lastMap = {};
        lastSnapshot.forEach(function(p) { lastMap[p.id] = p.confidence; });

        // Compute diffs
        var movers = [];
        currentSnapshot.forEach(function(p) {
          var prev = lastMap[p.id];
          if (prev !== undefined && prev !== p.confidence) {
            movers.push({ id: p.id, confidence: p.confidence, delta: p.confidence - prev, claim: '' });
          }
        });

        if (movers.length > 0) {
          // Attach claim text from currentSnapshot (which includes claim field)
          var claimMap = {};
          currentSnapshot.forEach(function(p) { if (p.claim) claimMap[p.id] = p.claim; });
          movers.forEach(function(m) { m.claim = claimMap[m.id] || ('P' + m.id); });

          movers.sort(function(a, b) { return Math.abs(b.delta) - Math.abs(a.delta); });
          var biggest = movers[0];
          var totalDelta = movers.reduce(function(sum, m) { return sum + Math.abs(m.delta); }, 0);
          renderBanner(movers.length, biggest, totalDelta);
        }
      }

      // Always update stored visit + snapshot
      saveVisit(currentSnapshot);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    // Also handle Astro view transitions
    document.addEventListener('astro:page-load', init);
  })();
  </script>

  <script is:inline>
    document.querySelectorAll('#hero-form, #cta-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        var btnText = btn.querySelector('.btn-text');
        var spinner = btn.querySelector('.btn-spinner');
        var input = form.querySelector('input[type="email"]');
        var email = input.value.trim();
        if (!email) return;

        var lang = document.documentElement.getAttribute('data-lang') || 'en';

        // Loading state
        var subscribingText = lang === 'zh' ? '提交中...' : 'Subscribing...';
        if (btnText) btnText.textContent = subscribingText;
        else btn.textContent = subscribingText;
        if (spinner) spinner.classList.remove('hidden');
        btn.disabled = true;

        // Store in localStorage as backup
        var subs = JSON.parse(localStorage.getItem('almanac-subs') || '[]');
        if (subs.indexOf(email) === -1) subs.push(email);
        localStorage.setItem('almanac-subs', JSON.stringify(subs));

        var successMsg = lang === 'zh'
          ? '搞定！明天下午2点（SGT）你会收到第一封。'
          : "You're in! First forecast arrives tomorrow at 6 AM UTC.";
        var successHTML = '<div class="flex items-center gap-2 py-3 text-almanac-green"><svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg><span class="font-medium text-sm">' + successMsg + '</span></div>';

        // Submit to Formspree
        fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ email: email, _subject: 'New Almanac subscriber' })
        }).then(function(r) {
          // Show success regardless (localStorage has the backup)
          form.outerHTML = successHTML;
        }).catch(function() {
          // Still show success — localStorage has the email
          form.outerHTML = successHTML;
        });
      });
    });
  </script>

