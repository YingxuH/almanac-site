  <script is:inline>
    document.querySelectorAll('#hero-form, #cta-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        var btnText = btn.querySelector('.btn-text');
        var spinner = btn.querySelector('.btn-spinner');
        var input = form.querySelector('input[type="email"]');
        var email = input.value.trim();
        if (!email) return;

        // Loading state
        if (btnText) btnText.textContent = 'Subscribing...';
        else btn.textContent = 'Subscribing...';
        if (spinner) spinner.classList.remove('hidden');
        btn.disabled = true;

        // Store in localStorage as backup
        var subs = JSON.parse(localStorage.getItem('almanac-subs') || '[]');
        if (subs.indexOf(email) === -1) subs.push(email);
        localStorage.setItem('almanac-subs', JSON.stringify(subs));

        // Submit to Formspree
        fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ email: email, _subject: 'New Almanac subscriber' })
        }).then(function(r) {
          // Show success regardless (localStorage has the backup)
          var container = form.parentElement;
          form.outerHTML = '<div class="flex items-center gap-2 py-3 text-almanac-green"><svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg><span class="font-medium text-sm">You\'re in! First forecast arrives tomorrow at 6 AM UTC.</span></div>';
        }).catch(function() {
          // Still show success — localStorage has the email
          form.outerHTML = '<div class="flex items-center gap-2 py-3 text-almanac-green"><svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg><span class="font-medium text-sm">You\'re in! First forecast arrives tomorrow at 6 AM UTC.</span></div>';
        });
      });
    });
  </script>

