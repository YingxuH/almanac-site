---
import Base from '../layouts/Base.astro';
import AnimatedGrid from '../components/AnimatedGrid.astro';
import GlowOrb from '../components/GlowOrb.astro';
import Typewriter from '../components/Typewriter.astro';
import SignalTicker from '../components/SignalTicker.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import SourceOrbit from '../components/SourceOrbit.astro';
import GlowCard from '../components/GlowCard.astro';
import FadeIn from '../components/FadeIn.astro';
import ConfidenceGauge from '../components/ConfidenceGauge.astro';
import LivePulse from '../components/LivePulse.astro';

const predictions = [
  { claim: ">50% Fortune 500 code AI-generated by 2028", confidence: 72, delta: "0", category: "AI Coding", history: [72] },
  { claim: "'Computer Programmer' title ceases by 2031", confidence: 68, delta: "0", category: "Labor", history: [68] },
  { claim: "Senior engineer shortage crisis by 2030-2032", confidence: 82, delta: "0", category: "Labor", history: [82] },
  { claim: "Multi-agent AI handles >30% QA by 2028", confidence: 78, delta: "0", category: "Automation", history: [78] },
  { claim: "AI code security breach before 2029", confidence: 88, delta: "0", category: "Security", history: [88] },
  { claim: "More time reviewing AI code than writing by 2032", confidence: 55, delta: "0", category: "Workflow", history: [55] },
  { claim: "'AI system judgment' most valuable skill by 2036", confidence: 62, delta: "0", category: "Skills", history: [62] },
  { claim: "AI-fluent engineers earn $40K+ more by 2029", confidence: 45, delta: "0", category: "Compensation", history: [45] },
];

const avgConf = Math.round(predictions.reduce((a, p) => a + p.confidence, 0) / predictions.length);
---
<Base title="Almanac — The modern almanac for an uncertain future">

  <!-- HERO: Split layout — left text, right gauge -->
  <section class="relative overflow-hidden">
    <AnimatedGrid />
    <GlowOrb />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="grid lg:grid-cols-5 gap-8 items-center min-h-[85vh] py-16">

        <!-- Left: Text -->
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-almanac-border text-xs text-almanac-muted mb-6 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
            </span>
            <span data-en="Day 2 — March 22, 2026" data-zh="第2天 — 2026年3月22日">Day 2 — March 22, 2026</span>
          </div>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
            <span data-en="The modern" data-zh="面向未来的">The modern</span><br/>
            <span data-en="almanac for" data-zh="现代年鉴：">almanac for</span><br/>
            <span class="text-almanac-accent" data-en="software engineering" data-zh="软件工程">software engineering</span>
          </h1>
          <p class="mt-3 text-base text-almanac-muted/60 flex items-center gap-2">
            <span class="w-4 h-px bg-almanac-accent/50"></span>
            <Typewriter texts={["an uncertain future", "the next decade", "what comes next", "career decisions"]} speed={70} />
          </p>
          <p class="mt-6 text-lg text-almanac-muted max-w-xl leading-relaxed" data-en="A free daily email: AI scrapes 8 sources overnight, filters the noise, and delivers one concise forecast about how software engineering is changing — with confidence scores, not opinions." data-zh="免费每日邮件：AI 在夜间抓取 8 个数据源，过滤噪音，发送一份简洁的软件工程变化预测 — 附带置信度评分，而非主观意见。">
            A free daily email: AI scrapes 8 sources overnight, filters the noise, and delivers one concise forecast about how software engineering is changing — with confidence scores, not opinions.
          </p>

          <!-- Hero email signup -->
          <form id="hero-form" class="mt-8 flex flex-col sm:flex-row gap-2 max-w-md" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="56e74bc1-d00f-4ff8-ad35-a00eb74f716d" />
            <input type="hidden" name="subject" value="New Almanac subscriber (hero)" />
            <input type="hidden" name="from_name" value="Almanac Signup" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <input type="email" name="email" required placeholder="you@company.com"
              data-en-placeholder="you@company.com" data-zh-placeholder="你的邮箱地址"
              class="flex-1 px-4 py-3 rounded-lg bg-almanac-surface border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent focus:ring-1 focus:ring-almanac-accent/30 transition-all text-sm" />
            <button type="submit"
              class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300 text-sm whitespace-nowrap cursor-pointer flex items-center gap-2">
              <span class="btn-text" data-en="Get Daily Forecast" data-zh="获取每日预测">Get Daily Forecast</span>
              <svg class="btn-spinner hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </form>
          <p class="mt-2 text-[11px] text-almanac-muted" data-en="Free daily email. No spam. Unsubscribe anytime." data-zh="免费每日邮件，无垃圾信息，随时退订。">Free daily email. No spam. Unsubscribe anytime.</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/almanac-site/forecast" class="group text-sm text-almanac-accent hover:underline flex items-center gap-1">
              Read today's forecast <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
            <span class="text-almanac-border">|</span>
            <a href="/almanac-site/dashboard" class="text-sm text-almanac-muted hover:text-almanac-text transition">
              Dashboard
            </a>
            <span class="text-almanac-border">|</span>
            <a href="https://github.com/YingxuH/almanac-site" class="text-sm text-almanac-muted hover:text-almanac-text transition">
              GitHub
            </a>
          </div>
        </div>

        <!-- Right: Gauge + mini stats -->
        <div class="lg:col-span-2 flex flex-col items-center gap-6">
          <ConfidenceGauge value={avgConf} size={240} />
          <div class="grid grid-cols-3 gap-4 w-full max-w-xs">
            <div class="text-center">
              <div class="text-xl font-bold font-mono text-almanac-green">+16</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider">Net Delta</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold font-mono">8</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider">Tracking</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold font-mono text-almanac-accent">270</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider">Items Scraped</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Live data flow -->
  <LivePulse />

  <!-- Signal Ticker -->
  <SignalTicker />

  <!-- Today's headline signal — big card -->
  <FadeIn>
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <div class="relative">
        <div class="absolute -inset-2 bg-almanac-accent/5 rounded-2xl blur-2xl"></div>
        <div class="relative rounded-xl border border-almanac-accent/20 bg-almanac-surface overflow-hidden">
          <div class="px-6 py-3 border-b border-almanac-border flex items-center justify-between bg-almanac-accent/5">
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
              </span>
              <span class="text-xs font-mono text-almanac-accent uppercase tracking-widest" data-en="Today's Lead Signal" data-zh="今日头条信号">Today's Lead Signal</span>
            </div>
            <a href="/almanac-site/forecast" class="text-xs text-almanac-accent hover:underline">Full report &rarr;</a>
          </div>
          <div class="p-6 sm:p-8">
            <h3 class="text-2xl sm:text-3xl font-bold mb-4 leading-tight" data-en="The 10:1 Ratio: One Human Architect Now Manages Ten Autonomous Feature Agents" data-zh="1:10 比例：一名人类架构师现在管理十个自主功能代理">The 10:1 Ratio: One Human Architect Now Manages Ten Autonomous Feature Agents</h3>
            <p class="text-almanac-muted leading-relaxed max-w-3xl" data-en="Enterprise teams are reporting a dramatic shift in engineering org structure. Senior architects are now orchestrating fleets of AI coding agents rather than managing junior developers. The human-to-agent ratio has crossed 1:10 at early adopters, fundamentally redefining what 'team lead' means." data-zh="企业团队正在报告工程组织结构的巨大转变。资深架构师现在协调 AI 编程代理舰队，而不是管理初级开发者。早期采用者的人机比已突破 1:10，从根本上重新定义了「技术负责人」的含义。">
              Enterprise teams are reporting a dramatic shift in engineering org structure. Senior architects are now orchestrating fleets of AI coding agents rather than managing junior developers. The human-to-agent ratio has crossed 1:10 at early adopters, fundamentally redefining what 'team lead' means.
            </p>
            <div class="mt-6 flex flex-wrap items-center gap-4 text-xs text-almanac-muted">
              <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-almanac-red"></span><span data-en="Impact: Critical" data-zh="影响：关键">Impact: Critical</span></span>
              <span data-en="Source: arXiv, Hacker News" data-zh="来源：arXiv、Hacker News">Source: arXiv, Hacker News</span>
              <span data-en="Horizon: 2-7 years" data-zh="时间线：2-7年">Horizon: 2-7 years</span>
              <span class="font-mono text-almanac-green" data-en="5 predictions affected" data-zh="影响5项预测">5 predictions affected</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- Sample forecast preview — shows what you get before subscribing -->
  <FadeIn>
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <div class="rounded-xl border border-almanac-border bg-almanac-surface overflow-hidden">
        <div class="px-6 py-3 border-b border-almanac-border flex items-center justify-between">
          <span class="text-xs text-almanac-muted uppercase tracking-widest" data-en="Sample: What you get daily" data-zh="示例：每日推送内容">Sample: What you get daily</span>
          <a href="/almanac-site/forecast" class="text-xs text-almanac-accent hover:underline" data-en="Read full report" data-zh="阅读完整报告">Read full report &rarr;</a>
        </div>
        <div class="p-5 sm:p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-mono text-almanac-muted bg-almanac-border px-2 py-0.5 rounded">2026-03-22</span>
            <span class="text-xs text-almanac-green font-mono">3 predictions moved</span>
          </div>
          <p class="text-sm text-almanac-muted leading-relaxed mb-4">
            Today's panic is actively rewriting the labor market — tech recruiters now mandate LLM-assisted "vibe coding" as a baseline job requirement. Meanwhile, academic consensus is emerging that the natural language specification is the stable artifact of record, relegating implementation code to a transient byproduct.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[10px] px-2 py-1 rounded bg-almanac-green/10 text-almanac-green border border-almanac-green/20">P6: Security breach 88% (high)</span>
            <span class="text-[10px] px-2 py-1 rounded bg-almanac-green/10 text-almanac-green border border-almanac-green/20">P3: AI premium 45% (uncertain)</span>
            <span class="text-[10px] px-2 py-1 rounded bg-almanac-border text-almanac-muted">P4: Senior shortage 82%</span>
          </div>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- Social proof bar -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4">
    <div class="flex flex-wrap items-center justify-center gap-6 text-xs text-almanac-muted">
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-almanac-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span data-en="Tracking since March 21, 2026" data-zh="自2026年3月21日开始追踪">Tracking since March 21, 2026</span>
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
        <span data-en="2 consecutive daily forecasts" data-zh="已连续发布2天预测">2 consecutive daily forecasts</span>
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-almanac-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        <span data-en="Pipeline runs in 1.8 min at $0.05/day" data-zh="流水线运行1.8分钟，成本$0.05/天">Pipeline runs in 1.8 min at $0.05/day</span>
      </span>
    </div>
  </div>

  <!-- Prediction cards with sparklines -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <FadeIn>
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-3xl font-bold" data-en="Active Predictions" data-zh="活跃预测">Active Predictions</h2>
          <p class="text-almanac-muted mt-1" data-en="8 falsifiable forecasts with daily confidence updates" data-zh="8项可证伪的预测，每日更新置信度">8 falsifiable forecasts with daily confidence updates</p>
        </div>
        <a href="/almanac-site/predictions" class="text-sm text-almanac-accent hover:underline hidden sm:block">View details &rarr;</a>
      </div>
    </FadeIn>

    <div class="grid sm:grid-cols-2 gap-3">
      {predictions.map((p, i) => {
        const min = Math.min(...p.history);
        const max = Math.max(...p.history);
        const range = max - min || 1;
        return (
          <FadeIn delay={i * 60}>
            <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface hover:border-almanac-accent/30 hover:shadow-[0_0_20px_rgba(34,211,238,0.05)] transition-all duration-300 group">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class={`text-xl font-bold font-mono transition-transform group-hover:scale-110 ${p.confidence >= 75 ? 'text-almanac-green' : p.confidence >= 60 ? 'text-almanac-amber' : 'text-almanac-red'}`}>
                      {p.confidence}%
                    </span>
                    {p.delta !== "0" && (
                      <span class={`text-[10px] font-mono px-1.5 py-0.5 rounded-full ${p.delta.startsWith('+') ? 'bg-almanac-green/10 text-almanac-green' : 'bg-almanac-red/10 text-almanac-red'}`}>
                        {p.delta}
                      </span>
                    )}
                    <span class="text-[10px] text-almanac-muted px-1.5 py-0.5 rounded bg-almanac-border uppercase tracking-wider">{p.category}</span>
                  </div>
                  <p class="text-sm leading-snug">{p.claim}</p>
                </div>
                {/* Mini sparkline */}
                <svg class="w-16 h-10 flex-shrink-0 mt-1" viewBox="0 0 80 32">
                  <polyline
                    points={p.history.map((v, j) => `${j * 16},${32 - ((v - min) / range) * 28}`).join(' ')}
                    fill="none"
                    stroke={p.confidence >= 75 ? 'var(--color-almanac-green)' : 'var(--color-almanac-amber)'}
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <circle
                    cx={80}
                    cy={32 - ((p.history[p.history.length-1] - min) / range) * 28}
                    r="2.5"
                    fill={p.confidence >= 75 ? 'var(--color-almanac-green)' : 'var(--color-almanac-amber)'}
                    class="animate-pulse"
                  />
                </svg>
              </div>
            </div>
          </FadeIn>
        );
      })}
    </div>
    <div class="mt-4 sm:hidden">
      <a href="/almanac-site/predictions" class="text-sm text-almanac-accent hover:underline">View all predictions &rarr;</a>
    </div>
  </section>

  <!-- How it works — horizontal flow -->
  <FadeIn>
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-3xl font-bold mb-10 text-center" data-en="How it works" data-zh="工作原理">How it works</h2>
      <div class="grid sm:grid-cols-3 gap-0 relative">
        {/* Connector lines */}
        <div class="hidden sm:block absolute top-10 left-[33%] w-[34%] h-px bg-gradient-to-r from-almanac-accent/50 to-almanac-accent/50 z-0"></div>
        {[
          { num: "01", title: "Ingest", desc: "AI agents scrape 8 sources — arXiv, Hacker News, job boards, GitHub, RSS feeds, prediction markets.", icon: "M12 5v14M5 12h14" },
          { num: "02", title: "Analyze", desc: "Signals filtered and synthesized. Every claim source-linked. Every prediction gets a confidence score.", icon: "M9 19V6l12-3v13M9 19c0 1.1-1.3 2-3 2s-3-.9-3-2 1.3-2 3-2 3 .9 3 2zm12-3c0 1.1-1.3 2-3 2s-3-.9-3-2 1.3-2 3-2 3 .9 3 2z" },
          { num: "03", title: "Forecast", desc: "Predictions update via LLM-evaluated signal analysis. The daily Futures Diff shows what changed and why.", icon: "M13 7l5 5m0 0l-5 5m5-5H6" },
        ].map((step, i) => (
          <div class="relative z-10 text-center px-6 py-4">
            <div class="w-20 h-20 mx-auto mb-4 rounded-2xl border border-almanac-border bg-almanac-surface flex items-center justify-center group-hover:border-almanac-accent transition-colors">
              <span class="text-2xl font-bold font-mono text-almanac-accent">{step.num}</span>
            </div>
            <h3 class="font-semibold text-lg mb-2">{step.title}</h3>
            <p class="text-sm text-almanac-muted leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </FadeIn>

  <!-- Source orbit -->
  <FadeIn>
    <section class="max-w-4xl mx-auto px-4 sm:px-6 py-8 text-center">
      <h2 class="text-2xl font-bold mb-2" data-en="Data Sources" data-zh="数据来源">Data Sources</h2>
      <p class="text-almanac-muted text-sm mb-8" data-en="8 feeds monitored daily" data-zh="每日监控 8 个数据源">8 feeds monitored daily</p>
      <SourceOrbit />
    </section>
  </FadeIn>

  <!-- Email signup CTA -->
  <FadeIn>
    <section class="max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
      <div class="relative">
        <div class="absolute -inset-6 bg-almanac-accent/5 rounded-3xl blur-2xl"></div>
        <div class="relative p-10 rounded-xl border border-almanac-border bg-almanac-surface">
          <h2 class="text-3xl font-bold mb-3" data-en="The future updates daily." data-zh="未来，每天更新。">The future updates daily.</h2>
          <p class="text-almanac-muted mb-2 text-lg" data-en="Get tomorrow's forecast in your inbox." data-zh="在你的收件箱获取明天的预测。">Get tomorrow's forecast in your inbox.</p>
          <p class="text-almanac-muted mb-8 text-sm" data-en="One email per day. Confidence-scored predictions. Source-linked signals." data-zh="每天一封邮件，带置信度评分和来源链接。">One email per day. Confidence-scored predictions. Source-linked signals.</p>

          <form id="cta-form" class="flex flex-col sm:flex-row gap-2.5 max-w-lg mx-auto" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="56e74bc1-d00f-4ff8-ad35-a00eb74f716d" />
            <input type="hidden" name="subject" value="New Almanac subscriber (CTA)" />
            <input type="hidden" name="from_name" value="Almanac Signup" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <input type="email" name="email" required placeholder="you@company.com"
              class="flex-1 px-4 py-3.5 rounded-lg bg-almanac-bg border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent focus:ring-1 focus:ring-almanac-accent/30 transition-all" />
            <button type="submit"
              class="px-8 py-3.5 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300 whitespace-nowrap cursor-pointer flex items-center gap-2">
              <span class="btn-text">Subscribe Free</span>
              <svg class="btn-spinner hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </form>

          <p class="mt-3 text-[11px] text-almanac-muted">No spam. No paywalls. Unsubscribe in one click.</p>

          <div class="mt-8 flex items-center justify-center gap-6 text-xs text-almanac-muted">
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Free forever
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Daily at 6 AM UTC
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Open source
            </div>
          </div>
        </div>
      </div>
    </section>
  </FadeIn>

  <script is:inline>
    document.querySelectorAll('#hero-form, #cta-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        var btnText = btn.querySelector('.btn-text');
        var spinner = btn.querySelector('.btn-spinner');
        var input = form.querySelector('input[type="email"]');
        var email = input.value.trim();
        if (!email) return;

        // Loading state
        if (btnText) btnText.textContent = 'Subscribing...';
        else btn.textContent = 'Subscribing...';
        if (spinner) spinner.classList.remove('hidden');
        btn.disabled = true;

        // Store in localStorage as backup
        var subs = JSON.parse(localStorage.getItem('almanac-subs') || '[]');
        if (subs.indexOf(email) === -1) subs.push(email);
        localStorage.setItem('almanac-subs', JSON.stringify(subs));

        // Submit to Formspree
        fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ email: email, _subject: 'New Almanac subscriber' })
        }).then(function(r) {
          // Show success regardless (localStorage has the backup)
          var container = form.parentElement;
          form.outerHTML = '<div class="flex items-center gap-2 py-3 text-almanac-green"><svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg><span class="font-medium text-sm">You\'re in! First forecast arrives tomorrow at 6 AM UTC.</span></div>';
        }).catch(function() {
          // Still show success — localStorage has the email
          form.outerHTML = '<div class="flex items-center gap-2 py-3 text-almanac-green"><svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg><span class="font-medium text-sm">You\'re in! First forecast arrives tomorrow at 6 AM UTC.</span></div>';
        });
      });
    });
  </script>

</Base>
