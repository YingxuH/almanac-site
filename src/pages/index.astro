---
import Base from '../layouts/Base.astro';
import AnimatedGrid from '../components/AnimatedGrid.astro';
import GlowOrb from '../components/GlowOrb.astro';
import Typewriter from '../components/Typewriter.astro';
import SignalTicker from '../components/SignalTicker.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import SourceOrbit from '../components/SourceOrbit.astro';
import GlowCard from '../components/GlowCard.astro';
import FadeIn from '../components/FadeIn.astro';
import ConfidenceGauge from '../components/ConfidenceGauge.astro';
import LivePulse from '../components/LivePulse.astro';

const predictions = [
  { claim: ">50% Fortune 500 code AI-generated by 2028", confidence: 74, delta: "+6", category: "AI Coding", history: [62,64,65,68,68,74] },
  { claim: "'Computer Programmer' title ceases by 2031", confidence: 77, delta: "+3", category: "Labor", history: [70,71,72,74,74,77] },
  { claim: "Senior engineer shortage crisis by 2030-2032", confidence: 80, delta: "+3", category: "Labor", history: [72,73,74,77,77,80] },
  { claim: "Multi-agent AI handles >30% QA by 2028", confidence: 76, delta: "0", category: "Automation", history: [72,73,74,76,76,76] },
  { claim: "AI code security breach before 2029", confidence: 72, delta: "0", category: "Security", history: [68,69,70,72,72,72] },
  { claim: "More time reviewing AI code than writing by 2032", confidence: 72, delta: "0", category: "Workflow", history: [65,67,68,72,72,72] },
  { claim: "'AI system judgment' most valuable skill by 2036", confidence: 82, delta: "+4", category: "Skills", history: [74,75,76,78,78,82] },
  { claim: "AI-fluent engineers earn $40K+ more by 2029", confidence: 71, delta: "0", category: "Compensation", history: [68,69,70,71,71,71] },
];

const avgConf = Math.round(predictions.reduce((a, p) => a + p.confidence, 0) / predictions.length);
---
<Base title="Almanac — The modern almanac for an uncertain future">

  <!-- HERO: Split layout — left text, right gauge -->
  <section class="relative overflow-hidden">
    <AnimatedGrid />
    <GlowOrb />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="grid lg:grid-cols-5 gap-8 items-center min-h-[85vh] py-16">

        <!-- Left: Text -->
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-almanac-border text-xs text-almanac-muted mb-6 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
            </span>
            Day 2 — March 22, 2026
          </div>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
            The modern<br/>almanac for<br/>
            <span class="text-almanac-accent">
              <Typewriter texts={["an uncertain future", "software engineering", "the next decade", "what comes next"]} speed={70} />
            </span>
          </h1>
          <p class="mt-6 text-lg text-almanac-muted max-w-xl leading-relaxed">
            AI reads thousands of signals daily. You read what matters — confidence-scored forecasts about the future of software engineering.
          </p>

          <!-- Hero email signup -->
          <form id="hero-form" class="mt-8 flex flex-col sm:flex-row gap-2 max-w-md" action="https://formspree.io/f/xyzgbkwl" method="POST">
            <input type="email" name="email" required placeholder="you@company.com"
              class="flex-1 px-4 py-3 rounded-lg bg-almanac-surface border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent focus:ring-1 focus:ring-almanac-accent/30 transition-all text-sm" />
            <button type="submit"
              class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300 text-sm whitespace-nowrap cursor-pointer">
              Get Daily Forecast
            </button>
            <input type="hidden" name="_subject" value="New Almanac subscriber" />
          </form>
          <p class="mt-2 text-[11px] text-almanac-muted">Free daily email. No spam. Unsubscribe anytime.</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/almanac-site/forecast" class="group text-sm text-almanac-accent hover:underline flex items-center gap-1">
              Read today's forecast <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
            <span class="text-almanac-border">|</span>
            <a href="/almanac-site/dashboard" class="text-sm text-almanac-muted hover:text-almanac-text transition">
              Dashboard
            </a>
            <span class="text-almanac-border">|</span>
            <a href="https://github.com/YingxuH/almanac" class="text-sm text-almanac-muted hover:text-almanac-text transition">
              GitHub
            </a>
          </div>
        </div>

        <!-- Right: Gauge + mini stats -->
        <div class="lg:col-span-2 flex flex-col items-center gap-6">
          <ConfidenceGauge value={avgConf} size={240} />
          <div class="grid grid-cols-3 gap-4 w-full max-w-xs">
            <div class="text-center">
              <div class="text-xl font-bold font-mono text-almanac-green">+16</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider">Net Delta</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold font-mono">8</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider">Tracking</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold font-mono text-almanac-accent">270</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider">Signals</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Live data flow -->
  <LivePulse />

  <!-- Signal Ticker -->
  <SignalTicker />

  <!-- Today's headline signal — big card -->
  <FadeIn>
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <div class="relative">
        <div class="absolute -inset-2 bg-almanac-accent/5 rounded-2xl blur-2xl"></div>
        <div class="relative rounded-xl border border-almanac-accent/20 bg-almanac-surface overflow-hidden">
          <div class="px-6 py-3 border-b border-almanac-border flex items-center justify-between bg-almanac-accent/5">
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
              </span>
              <span class="text-xs font-mono text-almanac-accent uppercase tracking-widest">Today's Lead Signal</span>
            </div>
            <a href="/almanac-site/forecast" class="text-xs text-almanac-accent hover:underline">Full report &rarr;</a>
          </div>
          <div class="p-6 sm:p-8">
            <h3 class="text-2xl sm:text-3xl font-bold mb-4 leading-tight">"Vibe Coding" Is Now a Mandatory Job Requirement</h3>
            <p class="text-almanac-muted leading-relaxed max-w-3xl">
              Recruiters are explicitly listing "experience building software with LLMs" as a mandatory requirement for standard engineering roles. The definition of a "competent engineer" has permanently shifted — universities are already adapting curricula.
            </p>
            <div class="mt-6 flex flex-wrap items-center gap-4 text-xs text-almanac-muted">
              <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-almanac-red"></span>Impact: Critical</span>
              <span>Source: Hacker News developer forums</span>
              <span>Horizon: 1-5 years</span>
              <span class="font-mono text-almanac-green">4 predictions affected</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- Prediction cards with sparklines -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <FadeIn>
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-3xl font-bold">Active Predictions</h2>
          <p class="text-almanac-muted mt-1">8 falsifiable forecasts with daily confidence updates</p>
        </div>
        <a href="/almanac-site/predictions" class="text-sm text-almanac-accent hover:underline hidden sm:block">View details &rarr;</a>
      </div>
    </FadeIn>

    <div class="grid sm:grid-cols-2 gap-3">
      {predictions.map((p, i) => {
        const min = Math.min(...p.history);
        const max = Math.max(...p.history);
        const range = max - min || 1;
        return (
          <FadeIn delay={i * 60}>
            <div class="p-4 rounded-xl border border-almanac-border bg-almanac-surface hover:border-almanac-accent/30 hover:shadow-[0_0_20px_rgba(34,211,238,0.05)] transition-all duration-300 group">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class={`text-xl font-bold font-mono transition-transform group-hover:scale-110 ${p.confidence >= 75 ? 'text-almanac-green' : p.confidence >= 60 ? 'text-almanac-amber' : 'text-almanac-red'}`}>
                      {p.confidence}%
                    </span>
                    {p.delta !== "0" && (
                      <span class={`text-[10px] font-mono px-1.5 py-0.5 rounded-full ${p.delta.startsWith('+') ? 'bg-almanac-green/10 text-almanac-green' : 'bg-almanac-red/10 text-almanac-red'}`}>
                        {p.delta}
                      </span>
                    )}
                    <span class="text-[10px] text-almanac-muted px-1.5 py-0.5 rounded bg-almanac-border uppercase tracking-wider">{p.category}</span>
                  </div>
                  <p class="text-sm leading-snug">{p.claim}</p>
                </div>
                {/* Mini sparkline */}
                <svg class="w-16 h-10 flex-shrink-0 mt-1" viewBox="0 0 80 32">
                  <polyline
                    points={p.history.map((v, j) => `${j * 16},${32 - ((v - min) / range) * 28}`).join(' ')}
                    fill="none"
                    stroke={p.confidence >= 75 ? 'var(--color-almanac-green)' : 'var(--color-almanac-amber)'}
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <circle
                    cx={80}
                    cy={32 - ((p.history[p.history.length-1] - min) / range) * 28}
                    r="2.5"
                    fill={p.confidence >= 75 ? 'var(--color-almanac-green)' : 'var(--color-almanac-amber)'}
                    class="animate-pulse"
                  />
                </svg>
              </div>
            </div>
          </FadeIn>
        );
      })}
    </div>
    <div class="mt-4 sm:hidden">
      <a href="/almanac-site/predictions" class="text-sm text-almanac-accent hover:underline">View all predictions &rarr;</a>
    </div>
  </section>

  <!-- How it works — horizontal flow -->
  <FadeIn>
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-3xl font-bold mb-10 text-center">How it works</h2>
      <div class="grid sm:grid-cols-3 gap-0 relative">
        {/* Connector lines */}
        <div class="hidden sm:block absolute top-10 left-[33%] w-[34%] h-px bg-gradient-to-r from-almanac-accent/50 to-almanac-accent/50 z-0"></div>
        {[
          { num: "01", title: "Ingest", desc: "AI agents scrape 10+ sources — arXiv, Hacker News, job boards, GitHub, RSS feeds, prediction markets.", icon: "M12 5v14M5 12h14" },
          { num: "02", title: "Analyze", desc: "Signals filtered and synthesized. Every claim source-linked. Every prediction gets a confidence score.", icon: "M9 19V6l12-3v13M9 19c0 1.1-1.3 2-3 2s-3-.9-3-2 1.3-2 3-2 3 .9 3 2zm12-3c0 1.1-1.3 2-3 2s-3-.9-3-2 1.3-2 3-2 3 .9 3 2z" },
          { num: "03", title: "Forecast", desc: "Predictions update via Bayesian reasoning. The daily Futures Diff shows what changed and why.", icon: "M13 7l5 5m0 0l-5 5m5-5H6" },
        ].map((step, i) => (
          <div class="relative z-10 text-center px-6 py-4">
            <div class="w-20 h-20 mx-auto mb-4 rounded-2xl border border-almanac-border bg-almanac-surface flex items-center justify-center group-hover:border-almanac-accent transition-colors">
              <span class="text-2xl font-bold font-mono text-almanac-accent">{step.num}</span>
            </div>
            <h3 class="font-semibold text-lg mb-2">{step.title}</h3>
            <p class="text-sm text-almanac-muted leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </FadeIn>

  <!-- Source orbit -->
  <FadeIn>
    <section class="max-w-4xl mx-auto px-4 sm:px-6 py-8 text-center">
      <h2 class="text-2xl font-bold mb-2">Data Sources</h2>
      <p class="text-almanac-muted text-sm mb-8">11 feeds monitored continuously</p>
      <SourceOrbit />
    </section>
  </FadeIn>

  <!-- Email signup CTA -->
  <FadeIn>
    <section class="max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
      <div class="relative">
        <div class="absolute -inset-6 bg-almanac-accent/5 rounded-3xl blur-2xl"></div>
        <div class="relative p-10 rounded-xl border border-almanac-border bg-almanac-surface">
          <h2 class="text-3xl font-bold mb-3">The future updates daily.</h2>
          <p class="text-almanac-muted mb-2 text-lg">Get tomorrow's forecast in your inbox.</p>
          <p class="text-almanac-muted mb-8 text-sm">One email per day. Confidence-scored predictions. Source-linked signals.</p>

          <form id="cta-form" class="flex flex-col sm:flex-row gap-2 max-w-lg mx-auto" action="https://formspree.io/f/xyzgbkwl" method="POST">
            <input type="email" name="email" required placeholder="you@company.com"
              class="flex-1 px-4 py-3.5 rounded-lg bg-almanac-bg border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent focus:ring-1 focus:ring-almanac-accent/30 transition-all" />
            <button type="submit"
              class="px-8 py-3.5 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300 whitespace-nowrap cursor-pointer">
              Subscribe Free
            </button>
            <input type="hidden" name="_subject" value="New Almanac subscriber (CTA)" />
          </form>

          <p class="mt-3 text-[11px] text-almanac-muted">No spam. No paywalls. Unsubscribe in one click.</p>

          <div class="mt-8 flex items-center justify-center gap-6 text-xs text-almanac-muted">
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Free forever
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Daily at 6 AM UTC
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              Open source
            </div>
          </div>
        </div>
      </div>
    </section>
  </FadeIn>

  <script is:inline>
    document.querySelectorAll('#hero-form, #cta-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        var input = form.querySelector('input[type="email"]');
        var email = input.value;
        btn.textContent = 'Sending...';
        btn.disabled = true;

        fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ email: email })
        }).then(function(r) {
          if (r.ok) {
            form.innerHTML = '<div class="flex items-center justify-center gap-2 py-3 text-almanac-green"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg><span class="font-medium">You\'re in! First forecast arrives tomorrow.</span></div>';
          } else {
            btn.textContent = 'Try again';
            btn.disabled = false;
          }
        }).catch(function() {
          btn.textContent = 'Try again';
          btn.disabled = false;
        });
      });
    });
  </script>

</Base>
