---
import Base from '../layouts/Base.astro';
import AnimatedGrid from '../components/AnimatedGrid.astro';
import GlowOrb from '../components/GlowOrb.astro';
import Typewriter from '../components/Typewriter.astro';
import SignalTicker from '../components/SignalTicker.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import SourceOrbit from '../components/SourceOrbit.astro';
import GlowCard from '../components/GlowCard.astro';
import FadeIn from '../components/FadeIn.astro';
import ConfidenceGauge from '../components/ConfidenceGauge.astro';
import LivePulse from '../components/LivePulse.astro';
import { loadPredictions, loadPredictionTrajectories, loadSiteMeta } from '../lib/data';
import SocialProof from '../components/SocialProof.astro';
import TrajectoryChart from '../components/TrajectoryChart.astro';
import fs from 'node:fs';
import path from 'node:path';

const allPreds = loadPredictions();
const trajectories = loadPredictionTrajectories();
const siteMeta = loadSiteMeta();

// Dynamic career stats from predictions.json
const findPred = (id: number) => allPreds.find((p: any) => p.id === id);
const devGrowth = findPred(6)?.confidence ?? 60;    // "Total developer headcount HIGHER in 2030"
const systemsSkills = findPred(36)?.confidence ?? 92; // "Systems programming premium HIGHER"
const bottomQuartile = findPred(23)?.confidence ?? 63; // "Bottom quartile salaries LOWER"

// Days since pipeline started running live
const launchDate = new Date('2026-03-20');
const daysLive = Math.max(1, Math.floor((Date.now() - launchDate.getTime()) / 86400000));

// Load latest report for the sample preview
let latestExcerpt = '';
let latestDate = '';
try {
  const reportsDir = path.resolve(process.cwd(), 'src', 'content', 'reports');
  const reports = fs.readdirSync(reportsDir).filter((f: string) => f.endsWith('.md') && !f.endsWith('.zh.md')).sort().reverse();
  if (reports.length > 0) {
    latestDate = reports[0].replace('.md', '');
    const content = fs.readFileSync(path.join(reportsDir, reports[0]), 'utf-8');
    // Extract executive summary
    const match = content.match(/### Executive Summary\s*\n([\s\S]*?)(?=\n###|\n---|\Z)/);
    if (match) latestExcerpt = match[1].trim().slice(0, 300).replace(/\n/g, ' ');
  }
} catch {}

// Find predictions that moved today (for sample preview badges)
const movedPreds = allPreds
  .filter((p: any) => p.confidence !== (p.previous ?? p.confidence))
  .sort((a: any, b: any) => Math.abs(b.confidence - (b.previous ?? b.confidence)) - Math.abs(a.confidence - (a.previous ?? a.confidence)))
  .slice(0, 3);

// Pick 8 representative predictions for the landing page:
// 2 highest confidence, 2 lowest, 2 most recently moved, 2 contrarian
const sorted = [...allPreds].sort((a, b) => b.confidence - a.confidence);
const moved = [...allPreds].filter(p => p.confidence !== (p.previous ?? p.confidence));
const contrarian = allPreds.filter(p => p.type === 'contrarian');

const picked = new Set<number>();
const predictions: any[] = [];
function addPred(p: any) {
  if (picked.has(p.id) || predictions.length >= 8) return;
  picked.add(p.id);
  const delta = p.confidence - (p.previous ?? p.confidence);
  predictions.push({
    claim: p.claim,
    claim_zh: p.claim_zh || p.claim,
    confidence: p.confidence,
    delta: delta === 0 ? "0" : (delta > 0 ? `+${delta}` : `${delta}`),
    category: p.category,
    category_zh: p.category_zh || p.category,
    history: [p.confidence],
    type: p.type || 'consensus',
  });
}
// 2 highest
sorted.slice(0, 2).forEach(addPred);
// 2 lowest
sorted.slice(-2).reverse().forEach(addPred);
// 2 most moved (or contrarian if none moved)
if (moved.length > 0) {
  moved.sort((a, b) => Math.abs(b.confidence - (b.previous ?? b.confidence)) - Math.abs(a.confidence - (a.previous ?? a.confidence)));
  moved.slice(0, 2).forEach(addPred);
}
// Fill remaining with contrarian picks spread across categories
const usedCats = new Set(predictions.map(p => p.category));
for (const p of contrarian) {
  if (predictions.length >= 8) break;
  if (!usedCats.has(p.category)) {
    addPred(p);
    usedCats.add(p.category);
  }
}
// If still < 8, fill from middle of the distribution
const midStart = Math.floor(sorted.length / 2) - 2;
for (let i = midStart; i < sorted.length && predictions.length < 8; i++) {
  addPred(sorted[i]);
}

const movedToday = moved.length;
const totalMovedPp = moved.reduce((sum: number, p: any) => sum + Math.abs(p.confidence - (p.previous ?? p.confidence)), 0);

// Top moved prediction for dynamic "Biggest Move" section
const topMoved = movedPreds.length > 0 ? movedPreds[0] : null;
const topMovedDelta = topMoved ? topMoved.confidence - (topMoved.previous ?? topMoved.confidence) : 0;
const topMovedDeltaStr = topMovedDelta > 0 ? `+${topMovedDelta}` : `${topMovedDelta}`;

const totalPreds = allPreds.length;
const avgConf = totalPreds > 0 ? Math.round(allPreds.reduce((a: number, p: any) => a + p.confidence, 0) / totalPreds) : 50;

// Nearest micro-prediction by resolution_date
const today = new Date();
today.setHours(0, 0, 0, 0);
const microPreds = allPreds
  .filter((p: any) => p.type === 'micro' && p.resolution_date)
  .map((p: any) => {
    const resDate = new Date(p.resolution_date);
    resDate.setHours(0, 0, 0, 0);
    const daysUntil = Math.ceil((resDate.getTime() - today.getTime()) / 86400000);
    return { ...p, daysUntil };
  })
  .filter((p: any) => p.daysUntil >= 0)
  .sort((a: any, b: any) => a.daysUntil - b.daysUntil);
const nearestMicro = microPreds.length > 0 ? microPreds[0] : null;
const nearestMicroWithin60 = nearestMicro && nearestMicro.daysUntil <= 60 ? nearestMicro : null;
---
<Base title="Almanac — The modern almanac for an uncertain future">

  <!-- HERO: Split layout — left text, right gauge -->
  <section class="relative overflow-hidden">
    <AnimatedGrid />
    <GlowOrb />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="grid lg:grid-cols-5 gap-8 items-center min-h-[60vh] sm:min-h-[85vh] py-10 sm:py-16">

        <!-- Left: Text -->
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-almanac-border text-xs text-almanac-muted mb-6 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-almanac-green opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-almanac-green"></span>
            </span>
            <span data-en={`Live — Day ${daysLive} of daily tracking`} data-zh={`已连续运行 ${daysLive} 天`}>Live — Day {daysLive} of daily tracking</span>
          </div>
          <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
            <span data-en="The modern" data-zh="给程序员的">The modern</span><br/>
            <span data-en="almanac for" data-zh="现代年鉴">almanac for</span><br/>
            <span class="text-almanac-accent" data-en="software engineering" data-zh="Almanac">software engineering</span>
          </h1>
          <p class="mt-3 text-base text-almanac-muted/60 flex items-center gap-2">
            <span class="w-4 h-px bg-almanac-accent/50"></span>
            <Typewriter texts={["an uncertain future", "the next decade", "what comes next", "career decisions"]} textsZh={["不确定的未来", "下一个十年", "接下来会发生什么", "你的职业选择"]} speed={70} />
          </p>
          <p class="mt-4 sm:mt-6 text-base sm:text-lg text-almanac-muted max-w-xl leading-relaxed">
            <span data-en="Will AI replace your job or make it more valuable?" data-zh="AI会取代你的工作还是让它更有价值？">Will AI replace your job or make it more valuable?</span>
            <span class="hidden sm:inline" data-en=" Will Rust salaries rise? Will junior hiring recover?" data-zh=" Rust薪资还涨不涨？初级岗还招不招？"> Will Rust salaries rise? Will junior hiring recover?</span>
            <span data-en={` ${totalPreds} predictions, updated daily from 17+ sources — career decisions based on evidence, not anxiety.`} data-zh={` ${totalPreds}项预测，17+数据源每日更新。用数据做职业决策，不靠焦虑。`}> {totalPreds} predictions, updated daily from 17+ sources — career decisions based on evidence, not anxiety.</span>
          </p>

          <p class="mt-3 text-xs text-almanac-muted/70 hidden sm:block" data-en="Unlike prediction markets, we track software-engineering-specific forecasts no one else covers — from AI debugging job emergence to Rust salary premiums — with daily updates tied to specific news events." data-zh="别人预测大盘，我们只盯软件工程——从AI会不会干掉初级岗，到Rust薪资溢价有多高——每次更新都有新闻源链接。">
            Unlike prediction markets, we track software-engineering-specific forecasts no one else covers — from AI debugging job emergence to Rust salary premiums — with daily updates tied to specific news events.
          </p>

          <!-- Hero email signup -->
          <form id="hero-form" class="mt-8 flex flex-col sm:flex-row gap-2 max-w-md" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="56e74bc1-d00f-4ff8-ad35-a00eb74f716d" />
            <input type="hidden" name="subject" value="New Almanac subscriber (hero)" />
            <input type="hidden" name="from_name" value="Almanac Signup" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <input type="email" name="email" required placeholder="you@company.com"
              data-en-placeholder="you@company.com" data-zh-placeholder="你的邮箱地址"
              class="flex-1 px-4 py-3 rounded-lg bg-almanac-surface border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent focus:ring-1 focus:ring-almanac-accent/30 transition-all text-sm" />
            <button type="submit"
              class="px-6 py-3 bg-almanac-accent text-almanac-bg font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(34,211,238,0.3)] transition-all duration-300 text-sm whitespace-nowrap cursor-pointer flex items-center gap-2">
              <span class="btn-text" data-en="Get Tomorrow's Forecast" data-zh="免费订阅">Get Tomorrow's Forecast</span>
              <svg class="btn-spinner hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </form>
          <p class="mt-2 text-[11px] text-almanac-muted" data-en="Free daily email. No spam. Unsubscribe anytime." data-zh="每天一封，不收费，不骚扰，一键退订。">Free daily email. No spam. Unsubscribe anytime.</p>

          <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2">
            <a href="/almanac-site/forecast" class="group text-sm text-almanac-accent hover:underline flex items-center gap-1" data-en="Read today's forecast" data-zh="看今天的预测">
              Read today's forecast <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
            <span class="hidden sm:inline text-almanac-border">|</span>
            <a href="/almanac-site/dashboard" class="text-sm text-almanac-muted hover:text-almanac-text transition" data-en="Dashboard" data-zh="数据面板">
              Dashboard
            </a>
            <span class="hidden sm:inline text-almanac-border">|</span>
            <a href="https://github.com/YingxuH/almanac" class="text-sm text-almanac-muted hover:text-almanac-text transition">
              GitHub
            </a>
          </div>
        </div>

        <!-- Right: Gauge + context + mini stats -->
        <div class="lg:col-span-2 flex flex-col items-center gap-4">
          <ConfidenceGauge value={avgConf} size={240} />
          <p class="text-xs text-almanac-muted text-center max-w-[240px] leading-relaxed" data-en={`${avgConf}% means roughly ${avgConf}-in-100 chance. Near 50% = genuine uncertainty — we quantify what we don't know, not just what we do.`} data-zh={`${avgConf}% 就是大约 ${avgConf}/100 的概率。越接近50%，说明越不确定——不确定性本身也是信息。`}>
            {avgConf}% means roughly {avgConf}-in-100 chance. Near 50% = genuine uncertainty — we quantify what we don't know, not just what we do.
          </p>
          <div class="grid grid-cols-3 gap-4 w-full max-w-xs">
            <div class="text-center">
              <div class="text-xl font-bold font-mono text-almanac-accent">{totalPreds}</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider" data-en="Predictions" data-zh="预测项">Predictions</div>
            </div>
            <a href="/almanac-site/forecast" class="text-center group">
              <div class="text-xl font-bold font-mono text-almanac-green group-hover:text-almanac-accent transition-colors">{totalMovedPp > 0 ? `${totalMovedPp}pp` : '—'}</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider group-hover:text-almanac-text transition-colors" data-en="Total Movement" data-zh="总变动幅度">Total Movement</div>
            </a>
            <div class="text-center">
              <div class="text-xl font-bold font-mono">17+</div>
              <div class="text-[10px] text-almanac-muted uppercase tracking-wider" data-en="Daily Sources" data-zh="数据源">Daily Sources</div>
            </div>
          </div>
          {/* Micro-prediction teaser (resolves soon) — falls back to contrarian */}
          {nearestMicroWithin60 ? (
            <a href="/almanac-site/predictions" class="mt-3 block w-full max-w-xs p-2.5 rounded-lg border border-almanac-accent/20 bg-almanac-accent/5 hover:border-almanac-accent/40 transition-colors text-left">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="text-[10px] font-bold text-almanac-accent uppercase tracking-wider px-1.5 py-0.5 rounded bg-almanac-accent/10 border border-almanac-accent/20"
                  data-en={`RESOLVES IN ${nearestMicroWithin60.daysUntil} DAY${nearestMicroWithin60.daysUntil === 1 ? '' : 'S'}`}
                  data-zh={`${nearestMicroWithin60.daysUntil}天后揭晓`}>
                  RESOLVES IN {nearestMicroWithin60.daysUntil} DAY{nearestMicroWithin60.daysUntil === 1 ? '' : 'S'}
                </span>
                <span class="text-sm font-bold font-mono text-almanac-accent">{nearestMicroWithin60.confidence}%</span>
              </div>
              <p class="text-xs text-almanac-muted leading-snug line-clamp-2" data-en={nearestMicroWithin60.claim} data-zh={nearestMicroWithin60.claim_zh || nearestMicroWithin60.claim}>{nearestMicroWithin60.claim}</p>
            </a>
          ) : contrarian.length > 0 && (() => {
            const pick = contrarian.find(p => p.confidence !== (p.previous ?? p.confidence)) || contrarian[0];
            return (
              <a href="/almanac-site/predictions" class="mt-3 block w-full max-w-xs p-2.5 rounded-lg border border-almanac-amber/20 bg-almanac-amber/5 hover:border-almanac-amber/40 transition-colors text-left">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-[10px] font-bold text-almanac-amber uppercase tracking-wider" data-en="Contrarian" data-zh="逆向预测">Contrarian</span>
                  <span class="text-sm font-bold font-mono text-almanac-amber">{pick.confidence}%</span>
                </div>
                <p class="text-xs text-almanac-muted leading-snug line-clamp-2" data-en={pick.claim} data-zh={pick.claim_zh || pick.claim}>{pick.claim}</p>
              </a>
            );
          })()}
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar — moved up, right after hero. Plain English, honest caveats inline -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4">
    <div class="flex flex-wrap items-center justify-center gap-6 text-xs text-almanac-muted">
      <a href="/almanac-site/validation" class="flex items-center gap-1.5 hover:text-almanac-accent transition-colors">
        <svg class="w-3.5 h-3.5 text-almanac-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span data-en="Tested against 20 past events: 16/20 directionally correct, Brier 0.155 (pre-launch backtest, not live)" data-zh="回测20个事件：16个判断正确，Brier 0.155（上线前测试，非实时）">Tested against 20 past events: 16/20 directionally correct, Brier 0.155 (pre-launch backtest, not live)</span>
      </a>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-almanac-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        <span data-en="10 AI personas (not humans) with different worldviews assess each prediction" data-zh="10个AI角色独立评估，不是一个模型一言堂">10 AI personas (not humans) with different worldviews assess each prediction</span>
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-almanac-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        <span data-en="We publish our misses — see all 4 we got wrong" data-zh="我们晒失败——4次判断错误，全部公开">We publish our misses — see all 4 we got wrong</span>
      </span>
    </div>
  </div>

  <!-- Social proof — operational credibility metrics, below trust bar -->
  <SocialProof
    pipelineRuns={siteMeta.total_pipeline_runs}
    signalsProcessed={siteMeta.total_signals_processed}
  />

  <!-- Micro-prediction countdown banner — prominent, above career section -->
  {nearestMicro && (
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3">
      <a href="/almanac-site/predictions" class="block p-3 rounded-xl border border-purple-500/20 bg-purple-500/5 hover:border-purple-500/40 transition-colors text-center">
        <div class="flex items-center justify-center gap-3 flex-wrap">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-purple-500/10 text-purple-600 text-xs font-bold">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span data-en={`First prediction resolves in ${nearestMicro.daysUntil} days`} data-zh={`首个预测 ${nearestMicro.daysUntil} 天后揭晓`}>First prediction resolves in {nearestMicro.daysUntil} days</span>
          </span>
          <span class="text-xs text-almanac-muted truncate max-w-md" data-en={nearestMicro.claim.slice(0, 80) + '...'} data-zh={(nearestMicro.claim_zh || nearestMicro.claim).slice(0, 80) + '...'}>{nearestMicro.claim.slice(0, 80)}...</span>
          <span class="text-xs font-mono text-purple-500">{nearestMicro.confidence}%</span>
        </div>
      </a>
    </div>
  )}

  <!-- What it means for your career — moved up as the emotional hook right after trust -->
  <div class="bg-almanac-surface/50 border-y border-almanac-border">
  <FadeIn>
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
      <h2 class="text-2xl font-bold mb-2 text-center" data-en="What the data says about your career" data-zh="关于你的职业，数据怎么说">What the data says about your career</h2>
      <p class="text-sm text-almanac-muted text-center mb-6" data-en="The three questions every software engineer is asking right now — with probabilities, not opinions." data-zh="程序员最焦虑的三个问题——这次用概率说话，不靠直觉。">The three questions every software engineer is asking right now — with probabilities, not opinions.</p>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface">
          <div class="text-2xl font-bold font-mono text-almanac-green mb-2">{devGrowth}%</div>
          <p class="text-sm font-medium mb-1" data-en="More developers, not fewer" data-zh="开发者会更多，不是更少">More developers, not fewer</p>
          <p class="text-xs text-almanac-muted" data-en="Our models suggest total developer headcount will likely GROW by 2030. Every previous automation wave expanded employment in the affected sector." data-zh="到2030年，开发者总数大概率增长。历史上每轮自动化都扩大了就业，这次也不例外。">Our models suggest total developer headcount will likely GROW by 2030. Every previous automation wave expanded employment in the affected sector.</p>
        </div>
        <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface">
          <div class="text-2xl font-bold font-mono text-almanac-amber mb-2">{systemsSkills}%</div>
          <p class="text-sm font-medium mb-1" data-en="Systems skills pay more" data-zh="底层技能更吃香">Systems skills pay more</p>
          <p class="text-xs text-almanac-muted" data-en="Rust, C++, and kernel development will command higher premiums as AI handles high-level code generation. Deep technical skills become more valuable, not less." data-zh="AI越擅长写业务代码，Rust/C++/内核开发的溢价越高。深度技术 > 泛技术，这个趋势在加速。">Rust, C++, and kernel development will command higher premiums as AI handles high-level code generation. Deep technical skills become more valuable, not less.</p>
        </div>
        <div class="p-5 rounded-xl border border-almanac-border bg-almanac-surface">
          <div class="text-2xl font-bold font-mono text-almanac-red mb-2">{bottomQuartile}%</div>
          <p class="text-sm font-medium mb-1" data-en="The floor drops, the ceiling rises" data-zh="下限降低，上限拉高">The floor drops, the ceiling rises</p>
          <p class="text-xs text-almanac-muted" data-en="Bottom-quartile developer salaries likely decline as AI commoditizes routine work — but Staff+ engineer pay is expected to rise 20%+. The gap widens. Upskilling matters more than ever." data-zh="AI让常规开发变便宜，底薪可能降。但Staff+薪酬预计涨20%以上。差距在拉大，提升技能是唯一出路。">Bottom-quartile developer salaries likely decline as AI commoditizes routine work — but Staff+ engineer pay is expected to rise 20%+. The gap widens. Upskilling matters more than ever.</p>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- Mid-page CTA — interest peaks after career cards -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 text-center">
    <form class="inline-flex flex-col sm:flex-row gap-2 items-center" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="56e74bc1-d00f-4ff8-ad35-a00eb74f716d" />
      <input type="hidden" name="subject" value="New Almanac subscriber (mid-page)" />
      <input type="hidden" name="from_name" value="Almanac Signup" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
      <input type="email" name="email" required placeholder="you@company.com"
        data-en-placeholder="you@company.com" data-zh-placeholder="你的邮箱地址"
        class="px-4 py-2.5 rounded-lg bg-almanac-surface border border-almanac-border text-almanac-text placeholder:text-almanac-muted/50 focus:outline-none focus:border-almanac-accent text-sm w-64" />
      <button type="submit"
